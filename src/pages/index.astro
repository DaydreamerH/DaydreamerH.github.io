---
import BaseLayout from "../layouts/BaseLayout.astro";

const modules = [
  {
    title: "知识库",
    status: "已启动",
    body: "沉淀游戏开发相关知识节点，支持阅读后跳转到 AI Coach 测试。",
    href: "/knowledge/"
  },
  {
    title: "AI 对话测试",
    status: "已启动",
    body: "使用自定义 API 与模型，围绕当前知识点生成问题、分析回答并继续追问。",
    href: "/coach/"
  },
  {
    title: "WebGL 实验",
    status: "待完成",
    body: "保留图形编程、Shader、渲染管线和可视化小实验的入口。",
    href: "/webgl/"
  }
];
---

<BaseLayout title="学习总览">
  <section class="workspace-hero">
    <div class="identity-panel">
      <p class="eyebrow">DaydreamerH</p>
      <h1>游戏开发训练工作台</h1>
      <p class="hero-text">
        用知识节点、AI 追问和图形实验，把游戏开发学习推进到能理解、能实现、能复盘的状态。
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/knowledge/">打开知识库</a>
        <a class="button" href="#modules">查看模块</a>
      </div>
    </div>
  </section>

  <section class="module-section" id="modules">
    <div class="module-grid">
      {modules.map((module) => (
        <a class={`module-card ${module.status === "待完成" ? "is-muted" : ""}`} href={module.href}>
          <div class="card-meta">
            <span class="pill">{module.status}</span>
          </div>
          <h3>{module.title}</h3>
          <p>{module.body}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="author-section">
    <div class="author-copy">
      <p class="eyebrow">Author</p>
      <h2>DaydreamerH</h2>
      <p>
        这个工作台会围绕个人学习节奏持续生长：先沉淀知识，再用测试、实验和 AI 追问把知识压实，逐步扩展到更多游戏开发方向。
      </p>
    </div>
    <div class="author-tags">
      <span>C++</span>
      <span>CG</span>
      <span>Gameplay</span>
      <span>Rendering</span>
    </div>
  </section>
</BaseLayout>
