---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getCategoryLabel } from "../data/navigation";

const recentDocs = (await getCollection("knowledge"))
  .filter((item) => item.data.status === "ready" && item.data.published !== false)
  .sort((a, b) => {
    const dateA = a.data.date ? Date.parse(a.data.date) : 0;
    const dateB = b.data.date ? Date.parse(b.data.date) : 0;
    if (dateA !== dateB) return dateB - dateA;
    return a.data.title.localeCompare(b.data.title, "zh-Hans-CN");
  })
  .slice(0, 5);

const modules = [
  {
    title: "知识库",
    status: "已启动",
    body: "按分类整理博客与学习笔记，并提供搜索、分页和详情阅读。",
    href: "/knowledge/"
  },
  {
    title: "AI 对话测试",
    status: "已启动",
    body: "使用自定义 API 与模型，基于选定文章生成问题并返回回答反馈。",
    href: "/coach/"
  },
  {
    title: "WebGL 实验",
    status: "待完成",
    body: "预留图形编程、Shader、渲染管线和可视化练习入口。",
    href: "/webgl/"
  }
];
---

<BaseLayout title="学习总览">
  <section class="workspace-hero">
    <div class="identity-panel recent-post-panel">
      <div class="inline-heading">
        <div>
          <p class="eyebrow">Recent Posts</p>
          <h1>近日博客</h1>
        </div>
        <a class="button" href="/knowledge/">全部文章</a>
      </div>
      <div class="recent-post-list">
        {recentDocs.map((doc) => (
          <a class="recent-post-item" href={`/knowledge/${doc.slug}/`}>
            <span>{doc.data.date ? doc.data.date.slice(0, 10) : "未标注日期"}</span>
            <strong>{doc.data.title}</strong>
            <small>{getCategoryLabel(doc.data.category)}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="module-section" id="modules">
    <div class="module-grid">
      {modules.map((module) => (
        <a class={`module-card ${module.status === "待完成" ? "is-muted" : ""}`} href={module.href}>
          {module.status === "待完成" && (
            <div class="card-meta">
              <span class="pill">{module.status}</span>
            </div>
          )}
          <h3>{module.title}</h3>
          <p>{module.body}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
