---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getCategoryLabel } from "../data/navigation";
import { graphicsLessonSummaries } from "../data/graphicsLessons";

const docs = (await getCollection("knowledge"))
  .filter((item) => item.data.status === "ready" && item.data.published !== false)

function parseDate(value = "") {
  const normalized = value.replaceAll(".", "-");
  const timestamp = Date.parse(normalized);
  return Number.isNaN(timestamp) ? 0 : timestamp;
}

const recentUpdates = [
  ...docs.map((doc) => ({
    type: "博客",
    title: doc.data.title,
    href: `/knowledge/${doc.slug}/`,
    date: doc.data.date ? doc.data.date.slice(0, 10) : "未标注日期",
    timestamp: parseDate(doc.data.date ?? ""),
    meta: getCategoryLabel(doc.data.category)
  })),
  ...graphicsLessonSummaries.map((lesson) => ({
    type: "实验",
    title: lesson.title,
    href: `/webgl/${lesson.id}/`,
    date: lesson.createdAt,
    timestamp: parseDate(lesson.createdAt),
    meta: lesson.category
  }))
]
  .sort((a, b) => {
    if (a.timestamp !== b.timestamp) return b.timestamp - a.timestamp;
    return a.title.localeCompare(b.title, "zh-Hans-CN");
  })
  .slice(0, 6);

const modules = [
  {
    title: "知识库",
    status: "已启动",
    body: "按分类整理博客与学习笔记，并提供搜索、分页和详情阅读。",
    href: "/knowledge/"
  },
  {
    title: "AI 对话测试",
    status: "已启动",
    body: "使用自定义 API 与模型，基于选定文章生成问题并返回回答反馈。",
    href: "/coach/"
  },
  {
    title: "WebGL 实验",
    status: "已启动",
    body: "提供 CG 实验课程入口，在浏览器中编辑 Three.js 与 Shader 代码，并通过 AI 引导完成 checkpoint。",
    href: "/webgl/"
  }
];
---

<BaseLayout title="学习总览">
  <section class="workspace-hero">
    <div class="identity-panel recent-post-panel">
      <div class="inline-heading">
        <div>
          <p class="eyebrow">Recent Updates</p>
          <h1>近日更新</h1>
        </div>
      </div>
      <div class="recent-post-list">
        {recentUpdates.map((item) => (
          <a class="recent-post-item" href={item.href}>
            <span>{item.date}</span>
            <b class="recent-update-type" data-type={item.type}>{item.type}</b>
            <strong>{item.title}</strong>
            <small>{item.meta}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="module-section" id="modules">
    <div class="module-grid">
      {modules.map((module) => (
        <a class={`module-card ${module.status === "待完成" ? "is-muted" : ""}`} href={module.href}>
          {module.status === "待完成" && (
            <div class="card-meta">
              <span class="pill">{module.status}</span>
            </div>
          )}
          <h3>{module.title}</h3>
          <p>{module.body}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
