---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChatSurface from "../../components/ChatSurface.astro";
import {
  Bot,
  BookOpen,
  Code2,
  Eye,
  EyeOff,
  FileDiff,
  Orbit,
  PanelLeftClose,
  PanelLeftOpen,
  Play,
  RefreshCcw,
  Settings2
} from "@lucide/astro";
import { graphicsLessons } from "../../data/graphicsLessons";

export function getStaticPaths() {
  return graphicsLessons.map((lesson) => ({
    params: { lessonId: lesson.id },
    props: { lesson }
  }));
}

const { lesson } = Astro.props;
const lessonPayload = JSON.stringify(lesson);
---

<BaseLayout title={`${lesson.title} - CG 实验`} description={lesson.description}>
  <section
    class="graphics-lab-page wide-surface"
    data-graphics-lab
    data-lesson-payload={lessonPayload}
    aria-label={`${lesson.title} 编辑器`}
  >
    <div class="graphics-lab is-guide-mode" data-lab-workspace data-workspace-mode="guide">
      <div class="lab-preview-panel">
        <div class="lab-panel-head" data-preview-drag>
          <div>
            <span>Preview</span>
            <i data-lab-status-dot data-state="idle" aria-hidden="true"></i>
          </div>
          <span class="lab-status" data-lab-status>等待运行</span>
          <div class="lab-preview-actions">
            <button type="button" data-orbit-toggle aria-label="切换轨道控制器" title="切换轨道控制器" aria-pressed="false">
              <Orbit size={16} aria-hidden="true" />
            </button>
            <button type="button" data-preview-hide aria-label="隐藏预览" title="隐藏预览">
              <EyeOff size={16} aria-hidden="true" />
            </button>
          </div>
        </div>

        <div class="lab-canvas-wrap">
          <canvas data-lab-canvas aria-label="实时图形预览"></canvas>
        </div>

        <div class="lab-error-box" data-lab-errors hidden></div>
        <span class="lab-preview-resize-handle" data-preview-resize="sw" aria-hidden="true"></span>
      </div>

      <nav class="lab-mode-sidebar" aria-label="实验工作区">
        <button
          class="lab-sidebar-toggle"
          type="button"
          data-toggle-lab-sidebar
          aria-label="收起文件栏"
          title="收起文件栏"
          aria-pressed="false"
        >
          <PanelLeftClose class="toggle-icon icon-sidebar-close" size={16} aria-hidden="true" />
          <PanelLeftOpen class="toggle-icon icon-sidebar-open" size={16} aria-hidden="true" />
          <span>切换边栏</span>
        </button>
        <div class="lab-file-tabs" role="tablist" aria-label="实验文件">
          <button class="lab-ai-tab is-active" type="button" role="tab" data-guide-tab aria-selected="true">
            <Bot size={16} aria-hidden="true" />
            <span>AI Guide</span>
          </button>
          <button class="lab-review-tab" type="button" role="tab" data-change-review-tab aria-selected="false">
            <FileDiff size={15} aria-hidden="true" />
            <span>最近修改</span>
          </button>
          <button type="button" role="tab" data-file-tab data-file="main.js" aria-selected="false">
            <Code2 size={15} aria-hidden="true" />
            <span>main.js</span>
          </button>
          <button type="button" role="tab" data-file-tab data-file="vertex.glsl" aria-selected="false">
            <Code2 size={15} aria-hidden="true" />
            <span>vertex.glsl</span>
          </button>
          <button type="button" role="tab" data-file-tab data-file="fragment.glsl" aria-selected="false">
            <Code2 size={15} aria-hidden="true" />
            <span>fragment.glsl</span>
          </button>
        </div>
        <div class="lab-sidebar-actions" aria-label="实验操作">
          <label class="lab-sidebar-action lab-auto-action" title="自动运行">
            <input type="checkbox" data-auto-run checked />
            <Settings2 size={16} aria-hidden="true" />
            <span>Auto</span>
          </label>
          <button class="lab-sidebar-action lab-run-action" type="button" data-run data-run-state="idle" data-run-feedback="">
            <Play size={16} aria-hidden="true" />
            <span data-run-label>运行</span>
          </button>
          <button class="lab-sidebar-action" type="button" data-reset-lab>
            <RefreshCcw size={16} aria-hidden="true" />
            <span>重置</span>
          </button>
        </div>
        <a class="lab-sidebar-link lab-sidebar-return" href="/webgl/">
          <BookOpen size={17} aria-hidden="true" />
          <span>返回课程</span>
        </a>
      </nav>

      <aside class="lab-editor-panel">
        <div class="lab-panel-head lab-workspace-head">
          <div class="lab-workspace-title">
            <span data-workspace-label>AI Guide</span>
            <strong data-workspace-title>{lesson.title}</strong>
          </div>

          <div class="lab-toolbar">
            <small class="lab-guide-state" data-guide-state data-state="waiting">等待 API</small>
            <button class="lab-preview-show" type="button" data-preview-show hidden aria-label="显示预览" title="显示预览">
              <Eye size={17} aria-hidden="true" />
            </button>
          </div>
        </div>

        <div class="lab-editor-shell">
          <div class="lab-editor-host" data-editor-host hidden></div>
          <section class="lab-change-review" data-change-review hidden aria-label="最近代码修改">
            <div class="change-review-empty" data-change-review-empty>
              暂无 AI 代码修改。AI 应用 patch 后，这里会显示最近一次变更。
            </div>
            <div class="change-review-body" data-change-review-body hidden></div>
          </section>
          <section class="lab-guide-workspace" data-guide-workspace aria-label="AI 图形学实验教练">
            <div class="guide-setup" data-guide-setup>
              <div class="guide-setup-body">
                <div class="guide-rule-card">
                  <strong>当前实验</strong>
                  <p>{lesson.description}</p>
                </div>

                <div class="guide-alert" data-guide-alert hidden></div>

                <div class="lab-ai-config">
                  <label>
                    <span>Endpoint</span>
                    <input data-guide-endpoint type="url" value="https://api.deepseek.com/chat/completions" autocomplete="off" />
                  </label>
                  <label>
                    <span>API Key</span>
                    <input data-guide-key type="password" placeholder="sk-..." autocomplete="off" />
                  </label>
                  <label>
                    <span>Model</span>
                    <input data-guide-model type="text" value="deepseek-v4-flash" autocomplete="off" />
                  </label>
                  <button type="button" data-guide-start>生成第一问</button>
                  <button type="button" data-guide-return hidden>返回对话</button>
                  <p>密钥只保存在当前页面内存中。AI 按课程 checkpoint 推进，代码变更优先使用本地预设 patch。</p>
                </div>
              </div>
            </div>

            <div class="guide-conversation" data-guide-conversation hidden>
              <small class="lab-guide-state" data-guide-state-mirror data-state="active" hidden>等待回答</small>

              <ChatSurface
                class="lab-chat-surface"
                ariaLabel="AI 图形学实验对话"
                alertData="data-guide-chat-alert"
                messageData="data-guide-log"
                messageClass="guide-log"
                formData="data-guide-form"
                formClass="guide-input-row"
                textareaId="guide-answer"
                textareaData="data-guide-input"
                textareaRows={2}
                placeholder="回答 AI 的问题，或说明你观察到的画面。Ctrl + Enter 提交。"
              >
                <div class="guide-actions" slot="composer-left">
                  <button class="composer-tool" type="button" data-guide-configure aria-label="API 设置">
                    <Settings2 size={17} aria-hidden="true" />
                    <span>API</span>
                  </button>
                </div>
              </ChatSurface>
            </div>
          </section>
        </div>
      </aside>
    </div>
  </section>

  <script>
    import "../../scripts/graphics-lab";
  </script>
</BaseLayout>
