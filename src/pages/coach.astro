---
import BaseLayout from "../layouts/BaseLayout.astro";

const knowledgeNodes = [
  {
    id: "ue-cpp-reflection",
    category: "UE 核心",
    href: "/knowledge/ue-cpp-reflection/",
    title: "UE C++ 反射系统",
    description: "理解 UCLASS、UPROPERTY、UFUNCTION 如何把 C++ 类型暴露给编辑器、蓝图、序列化和 GC。",
    tags: ["UObject", "Reflection", "UPROPERTY", "GC", "Blueprint"],
    feedback: [
      "检查回答是否提到 GC 可达性和 UObject 生命周期。",
      "注意区分反射、编辑器暴露、蓝图调用、序列化和网络复制。",
      "更好的回答会说明普通 C++ 指针和 UObject 引用在 UE 中的管理差异。"
    ]
  },
  {
    id: "ue-gameplay-framework",
    category: "Gameplay",
    href: "/knowledge/ue-gameplay-framework/",
    title: "Gameplay Framework 基础",
    description: "掌握 GameMode、GameState、PlayerController、Pawn、Character 等核心类的职责边界。",
    tags: ["GameMode", "GameState", "PlayerController", "Pawn", "Character"],
    feedback: [
      "检查回答是否区分服务器专属规则与客户端可见状态。",
      "注意 PlayerController、PlayerState、Pawn 的职责边界。",
      "更好的回答会结合重生、分数、队伍状态或多人同步场景。"
    ]
  },
  {
    id: "modern-cpp-raii",
    category: "C++ 基础",
    href: "/knowledge/modern-cpp-raii/",
    title: "现代 C++ 与 RAII",
    description: "用资源获取即初始化的思路管理内存、文件句柄、锁和临时对象，减少生命周期错误。",
    tags: ["RAII", "unique_ptr", "lifetime", "resource"],
    feedback: [
      "检查回答是否落到所有权和生命周期，而不是只说智能指针。",
      "注意区分标准 C++ 对象、UE 非 UObject 对象和 UObject。",
      "更好的回答会说明提前返回、异常路径或资源释放顺序。"
    ]
  },
  {
    id: "portfolio-demo-scope",
    category: "作品集",
    href: "/knowledge/portfolio-demo-scope/",
    title: "UE5 作品 Demo 范围控制",
    description: "把作品集项目控制在能完成、能展示、能被面试深挖的范围内。",
    tags: ["Portfolio", "Demo", "Interview"],
    feedback: [
      "检查回答是否包含明确的玩法目标和技术目标。",
      "注意说明可展示证据：源码、视频、性能记录、设计复盘。",
      "更好的回答会主动指出取舍、风险和后续可扩展方向。"
    ]
  }
];
const activeNode = knowledgeNodes[0];
const categories = [...new Set(knowledgeNodes.map((node) => node.category))];
---

<BaseLayout title="AI Coach" description="DaydreamerH 的 UE5 知识点提问工作区。">
  <section class="coach-head">
    <div>
      <p class="eyebrow">AI Coach</p>
      <h1>知识点提问</h1>
      <p>
        选择一个知识点，填写 API 后输入测试内容，由你的模型生成反馈摘要。当前流程不保存个人数据。
      </p>
    </div>
    <div class="coach-status">
      <span class="pill">当前测试</span>
      <strong data-current-node-title>{activeNode.title}</strong>
      <small>知识点提问</small>
    </div>
  </section>

  <section class="coach-layout compact" data-coach-layout aria-label="AI Coach 知识点提问">
    <aside class="coach-sidebar">
      <div class="panel-block">
        <div class="panel-heading">
          <span>测试目标与上下文</span>
          <strong><a data-context-link href={`/knowledge/${activeNode.id}/`}>{activeNode.title}</a></strong>
        </div>
        <label class="select-field compact-select">
          <span>分类</span>
          <select data-category-select>
            {categories.map((category) => (
              <option value={category} selected={category === activeNode.category}>{category}</option>
            ))}
          </select>
        </label>
        <div class="node-list" data-node-list>
          {knowledgeNodes
            .filter((node) => node.category === activeNode.category)
            .map((node, index) => (
            <button class={index === 0 ? "is-active" : ""} data-node={node.id} type="button">
              <span>{node.title}</span>
              <small>{node.category}</small>
            </button>
          ))}
        </div>
        <p class="muted-copy" data-context-description>{activeNode.description}</p>
        <div class="tag-row" data-context-tags>
          {activeNode.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <div class="context-actions">
          <a class="context-return" data-context-return href={`/knowledge/${activeNode.id}/`}>
            返回知识详情
          </a>
          <a class="context-return" href="/knowledge/">返回知识库</a>
        </div>
      </div>
    </aside>

    <section class="chat-panel">
      <div class="chat-toolbar">
        <div>
          <span>Session</span>
          <strong data-session-title>{activeNode.title}</strong>
        </div>
        <div class="toolbar-actions">
          <button type="button" data-toggle-left>折叠左侧</button>
          <button type="button" data-toggle-right>折叠右侧</button>
          <button type="button" data-reset>重新开始</button>
        </div>
      </div>

      <div class="message-list" aria-label="AI 对话" data-message-list></div>

      <form class="answer-box" data-answer-form>
        <label for="answer">你的输入</label>
        <textarea id="answer" rows="4" data-answer-input placeholder="填写 API 后，输入你想测试的回答或让模型基于当前知识点提问。"></textarea>
        <div>
          <span data-answer-hint>先填写右侧 API 信息，再提交你的输入。</span>
          <button type="submit">提交</button>
        </div>
      </form>
    </section>

    <aside class="feedback-panel">
      <div class="panel-block feedback-summary">
        <div class="panel-heading">
          <span>反馈摘要</span>
          <strong data-feedback-title>等待回答</strong>
        </div>
        <p class="feedback-source" data-feedback-source>请先填写右侧 API 信息。</p>
        <ul class="feedback-list" data-feedback-list>
          <li>提交输入后，这里会显示针对当前知识点的反馈要点。</li>
          <li>不会保存到浏览器存储或任何持久化位置。</li>
        </ul>
      </div>

      <div class="panel-block">
        <div class="panel-heading">
          <span>AI API</span>
          <strong>当前页面临时使用</strong>
        </div>
        <form class="api-config" data-api-config>
          <label>
            <span>Endpoint</span>
            <input
              data-api-endpoint
              type="url"
              placeholder="https://api.openai.com/v1/chat/completions"
              autocomplete="off"
            />
          </label>
          <label>
            <span>API Key</span>
            <input data-api-key type="password" placeholder="sk-..." autocomplete="off" />
          </label>
          <label>
            <span>Model</span>
            <input data-api-model type="text" placeholder="填写你的模型名" autocomplete="off" />
          </label>
        </form>
        <p class="api-note">密钥只保存在当前页面内存中，刷新后清空。浏览器直连 API 需要服务商允许 CORS。</p>
      </div>
    </aside>
  </section>

  <script>
    const nodes = {
      "ue-cpp-reflection": {
        category: "UE 核心",
        href: "/knowledge/ue-cpp-reflection/",
        title: "UE C++ 反射系统",
        description: "理解 UCLASS、UPROPERTY、UFUNCTION 如何把 C++ 类型暴露给编辑器、蓝图、序列化和 GC。",
        tags: ["UObject", "Reflection", "UPROPERTY", "GC", "Blueprint"],
        feedback: [
          "检查回答是否提到 GC 可达性和 UObject 生命周期。",
          "注意区分反射、编辑器暴露、蓝图调用、序列化和网络复制。",
          "更好的回答会说明普通 C++ 指针和 UObject 引用在 UE 中的管理差异。"
        ]
      },
      "ue-gameplay-framework": {
        category: "Gameplay",
        href: "/knowledge/ue-gameplay-framework/",
        title: "Gameplay Framework 基础",
        description: "掌握 GameMode、GameState、PlayerController、Pawn、Character 等核心类的职责边界。",
        tags: ["GameMode", "GameState", "PlayerController", "Pawn", "Character"],
        feedback: [
          "检查回答是否区分服务器专属规则与客户端可见状态。",
          "注意 PlayerController、PlayerState、Pawn 的职责边界。",
          "更好的回答会结合重生、分数、队伍状态或多人同步场景。"
        ]
      },
      "modern-cpp-raii": {
        category: "C++ 基础",
        href: "/knowledge/modern-cpp-raii/",
        title: "现代 C++ 与 RAII",
        description: "用资源获取即初始化的思路管理内存、文件句柄、锁和临时对象，减少生命周期错误。",
        tags: ["RAII", "unique_ptr", "lifetime", "resource"],
        feedback: [
          "检查回答是否落到所有权和生命周期，而不是只说智能指针。",
          "注意区分标准 C++ 对象、UE 非 UObject 对象和 UObject。",
          "更好的回答会说明提前返回、异常路径或资源释放顺序。"
        ]
      },
      "portfolio-demo-scope": {
        category: "作品集",
        href: "/knowledge/portfolio-demo-scope/",
        title: "UE5 作品 Demo 范围控制",
        description: "把作品集项目控制在能完成、能展示、能被面试深挖的范围内。",
        tags: ["Portfolio", "Demo", "Interview"],
        feedback: [
          "检查回答是否包含明确的玩法目标和技术目标。",
          "注意说明可展示证据：源码、视频、性能记录、设计复盘。",
          "更好的回答会主动指出取舍、风险和后续可扩展方向。"
        ]
      }
    };

    const params = new URLSearchParams(window.location.search);
    const categories = [...new Set(Object.values(nodes).map((node) => node.category))];
    const state = {
      node: nodes[params.get("node")] ? params.get("node") : "ue-cpp-reflection",
      category: nodes[params.get("node")]?.category || "UE 核心"
    };

    const layout = document.querySelector("[data-coach-layout]");
    const messageList = document.querySelector("[data-message-list]");
    const answerForm = document.querySelector("[data-answer-form]");
    const answerInput = document.querySelector("[data-answer-input]");
    const answerHint = document.querySelector("[data-answer-hint]");
    const feedbackTitle = document.querySelector("[data-feedback-title]");
    const feedbackList = document.querySelector("[data-feedback-list]");
    const feedbackSource = document.querySelector("[data-feedback-source]");
    const apiEndpointInput = document.querySelector("[data-api-endpoint]");
    const apiKeyInput = document.querySelector("[data-api-key]");
    const apiModelInput = document.querySelector("[data-api-model]");
    const categorySelect = document.querySelector("[data-category-select]");
    const nodeList = document.querySelector("[data-node-list]");

    function createMessage(role, label, body) {
      const article = document.createElement("article");
      article.className = `message ${role === "user" ? "from-user" : "from-coach"}`;
      article.innerHTML = `<span></span><p></p>`;
      article.querySelector("span").textContent = label;
      article.querySelector("p").textContent = body;
      return article;
    }

    function renderFeedback(title, items) {
      feedbackTitle.textContent = title;
      feedbackList.replaceChildren(...items.map((item) => {
        const li = document.createElement("li");
        li.textContent = item;
        return li;
      }));
    }

    function setFeedbackSource(text, tone = "muted") {
      feedbackSource.textContent = text;
      feedbackSource.dataset.tone = tone;
    }

    function renderContext() {
      const node = nodes[state.node];
      document.querySelector("[data-current-node-title]").textContent = node.title;
      document.querySelector("[data-context-description]").textContent = node.description;
      document.querySelector("[data-session-title]").textContent = node.title;

      const contextLink = document.querySelector("[data-context-link]");
      const contextReturn = document.querySelector("[data-context-return]");
      contextLink.textContent = node.title;
      contextLink.href = node.href;
      contextReturn.href = node.href;

      document.querySelector("[data-context-tags]").replaceChildren(...node.tags.map((tag) => {
        const span = document.createElement("span");
        span.textContent = tag;
        return span;
      }));

      categorySelect.value = state.category;
      renderNodeList();
    }

    function renderNodeList() {
      const entries = Object.entries(nodes).filter(([, node]) => node.category === state.category);
      nodeList.replaceChildren(...entries.map(([id, node]) => {
        const button = document.createElement("button");
        button.type = "button";
        button.dataset.node = id;
        button.classList.toggle("is-active", id === state.node);
        button.innerHTML = "<span></span><small></small>";
        button.querySelector("span").textContent = node.title;
        button.querySelector("small").textContent = node.category;
        button.addEventListener("click", () => selectNode(id));
        return button;
      }));
    }

    function resetSession() {
      const node = nodes[state.node];
      renderContext();
      messageList.replaceChildren(createMessage(
        "coach",
        "AI Coach",
        "请先在右侧填写 Endpoint、API Key 和 Model。配置完成后，输入你的回答或测试需求，我会基于当前知识点调用模型生成反馈。"
      ));
      renderFeedback("等待 API", [
        "填写右侧 API 信息后提交内容，这里会显示 AI 反馈摘要。",
        "不会保存到浏览器存储或任何持久化位置。"
      ]);
      setFeedbackSource("请先填写右侧 API 信息。");
      answerInput.value = "";
      answerHint.textContent = "先填写右侧 API 信息，再提交你的输入。";
    }

    function normalizeEndpoint(value) {
      const trimmed = value.trim().replace(/\/+$/, "");
      if (!trimmed) return "";
      if (trimmed.endsWith("/chat/completions")) return trimmed;
      if (trimmed.endsWith("/v1")) return `${trimmed}/chat/completions`;
      return `${trimmed}/v1/chat/completions`;
    }

    function hasApiConfig() {
      return apiEndpointInput.value.trim() && apiKeyInput.value.trim() && apiModelInput.value.trim();
    }

    async function requestAiFeedback(node, answer) {
      const endpoint = normalizeEndpoint(apiEndpointInput.value);
      const response = await fetch(endpoint, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${apiKeyInput.value.trim()}`
        },
        body: JSON.stringify({
          model: apiModelInput.value.trim(),
          temperature: 0.2,
          messages: [
            {
              role: "system",
              content: [
                "你是一个面向 UE5 游戏开发学习的知识点测试教练。",
                "请只输出简洁的中文反馈摘要，不要继续追问，不要评分，不要保存或索要个人信息。",
                "如果用户要求出题，请先给出一个围绕知识点的问题；如果用户提交了回答，请给出反馈摘要。",
                "输出必须简洁，使用 3 到 5 个短要点，每个要点单独一行。"
              ].join("\n")
            },
            {
              role: "user",
              content: [
                `知识点：${node.title}`,
                `知识点说明：${node.description}`,
                `用户输入：${answer}`,
                "请基于当前知识点处理用户输入。"
              ].join("\n\n")
            }
          ]
        })
      });

      if (!response.ok) {
        const detail = await response.text();
        throw new Error(`API 请求失败：${response.status} ${detail.slice(0, 180)}`);
      }

      const data = await response.json();
      const content = data?.choices?.[0]?.message?.content;
      if (!content) {
        throw new Error("API 返回中没有可用的 message.content。");
      }
      return content
        .split(/\n+/)
        .map((line) => line.replace(/^[-*•\d.\s]+/, "").trim())
        .filter(Boolean);
    }

    answerForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const answer = answerInput.value.trim();
      if (!answer) {
        answerHint.textContent = "先写下你的输入，再提交。";
        answerInput.focus();
        return;
      }

      const node = nodes[state.node];
      if (!hasApiConfig()) {
        messageList.append(createMessage(
          "coach",
          "AI Coach",
          "请先在右侧填写 Endpoint、API Key 和 Model。填写完成后再次提交，我会用你的模型生成反馈摘要。"
        ));
        renderFeedback("需要 API 信息", [
          "Endpoint、API Key 和 Model 都是必填项。",
          "配置只在当前页面内存中使用，刷新后清空。",
          "如果服务商不允许浏览器跨域请求，需要后续增加代理层。"
        ]);
        setFeedbackSource("尚未调用模型。", "error");
        answerHint.textContent = "填写右侧 API 信息后再次提交。";
        messageList.scrollTop = messageList.scrollHeight;
        return;
      }

      messageList.append(createMessage("user", "DaydreamerH", answer));
      renderFeedback("生成中", ["正在请求 AI 生成反馈摘要..."]);
      setFeedbackSource("使用你填写的 API 生成反馈。");
      answerForm.querySelector("button").disabled = true;

      try {
        const aiFeedback = await requestAiFeedback(node, answer);
        renderFeedback("AI 反馈摘要", aiFeedback);
        messageList.append(createMessage("coach", "AI Coach", aiFeedback.join("\n")));
        setFeedbackSource("来自当前页面填写的模型配置。", "success");
      } catch (error) {
        renderFeedback("API 调用失败", [
          error.message,
          "请检查 Endpoint 是否为 OpenAI-compatible Chat Completions 地址，模型名是否正确，以及服务商是否允许浏览器跨域请求。"
        ]);
        messageList.append(createMessage("coach", "AI Coach", "API 调用失败，请检查右侧配置后再次提交。"));
        setFeedbackSource("已停止本次 API 调用，未保存任何配置。", "error");
      } finally {
        answerForm.querySelector("button").disabled = false;
      }

      answerInput.value = "";
      answerHint.textContent = "可以修改答案后再次提交，或切换知识点。";
      messageList.scrollTop = messageList.scrollHeight;
    });

    function selectNode(id) {
      state.node = id;
      state.category = nodes[id].category;
      const url = new URL(window.location.href);
      url.searchParams.set("node", state.node);
      history.replaceState(null, "", url);
      resetSession();
    }

    categorySelect.addEventListener("change", () => {
      state.category = categorySelect.value;
      const firstNode = Object.entries(nodes).find(([, node]) => node.category === state.category)?.[0];
      if (firstNode) selectNode(firstNode);
    });

    document.querySelector("[data-toggle-left]").addEventListener("click", (event) => {
      layout.classList.toggle("is-left-collapsed");
      event.currentTarget.textContent = layout.classList.contains("is-left-collapsed") ? "展开左侧" : "折叠左侧";
    });

    document.querySelector("[data-toggle-right]").addEventListener("click", (event) => {
      layout.classList.toggle("is-right-collapsed");
      event.currentTarget.textContent = layout.classList.contains("is-right-collapsed") ? "展开右侧" : "折叠右侧";
    });

    document.querySelector("[data-reset]").addEventListener("click", resetSession);
    resetSession();
  </script>
</BaseLayout>
