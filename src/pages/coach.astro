---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChatSurface from "../components/ChatSurface.astro";
import { getCollection } from "astro:content";
import { ChevronDown, ChevronUp, Copy, PanelLeftClose, PanelLeftOpen, Sparkles } from "@lucide/astro";
import { getCategoryLabel, getLevelLabel } from "../data/navigation";

const docs = (await getCollection("knowledge"))
  .filter((item) => item.data.status === "ready" && item.data.published !== false)
  .sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    const dateA = a.data.date ? Date.parse(a.data.date) : 0;
    const dateB = b.data.date ? Date.parse(b.data.date) : 0;
    if (dateA !== dateB) return dateB - dateA;
    return a.data.title.localeCompare(b.data.title, "zh-Hans-CN");
  });

const knowledgeNodes = docs.map((doc) => ({
  id: doc.slug,
  category: getCategoryLabel(doc.data.category),
  href: `/knowledge/${doc.slug}/`,
  title: doc.data.title,
  description: doc.data.description,
  track: doc.data.track,
  level: getLevelLabel(doc.data.level),
  minutes: doc.data.minutes,
  prerequisites: doc.data.prerequisites,
  tags: doc.data.tags,
  body: doc.body.trim()
}));
const activeNode = knowledgeNodes[0];
const categories = [...new Set(knowledgeNodes.map((node) => node.category))];
const nodesJson = JSON.stringify(Object.fromEntries(knowledgeNodes.map((node) => [node.id, node])));
---

<BaseLayout title="AI Coach" description="DaydreamerH 的知识点提问工作区。">
  <section class="coach-layout compact" data-coach-layout aria-label="AI Coach 知识点提问">
    <aside class="coach-sidebar">
      <div class="panel-block">
        <div class="panel-heading panel-heading-row">
          <div>
            <span>测试目标与上下文</span>
            <strong><a data-context-link href={`/knowledge/${activeNode.id}/`}>{activeNode.title}</a></strong>
          </div>
          <button class="side-toggle" type="button" data-toggle-left aria-label="折叠左侧面板" aria-expanded="true">
            <PanelLeftClose class="toggle-icon icon-collapse" size={18} aria-hidden="true" />
            <PanelLeftOpen class="toggle-icon icon-expand" size={18} aria-hidden="true" />
          </button>
        </div>
        <div class="node-picker is-collapsed" data-node-picker>
          <div class="node-picker-head">
            <span data-node-count></span>
            <button
              class="picker-toggle"
              type="button"
              data-toggle-picker
              aria-label="展开文章选择"
              aria-expanded="false"
            >
              <ChevronDown class="toggle-icon icon-expand" size={17} aria-hidden="true" />
              <ChevronUp class="toggle-icon icon-collapse" size={17} aria-hidden="true" />
            </button>
          </div>
          <button class="selected-node-card" type="button" data-selected-node-card>
            <span data-selected-node-title>{activeNode.title}</span>
          </button>
          <div class="node-picker-body" data-node-picker-body>
            <label class="select-field compact-select">
              <span>分类</span>
              <select data-category-select>
                <option value="all">全部分类</option>
                {categories.map((category) => (
                  <option value={category} selected={category === activeNode.category}>{category}</option>
                ))}
              </select>
            </label>
            <label class="search-field coach-search">
              <span>搜索文章</span>
              <input data-node-search type="search" placeholder="输入标题、标签或分类..." autocomplete="off" />
            </label>
            <div class="node-list" data-node-list>
              {knowledgeNodes
                .filter((node) => node.category === activeNode.category)
                .map((node, index) => (
                <button class={index === 0 ? "is-active" : ""} data-node={node.id} type="button">
                  <span>{node.title}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
        <p class="muted-copy" data-context-description>{activeNode.description}</p>
        <div class="tag-row" data-context-tags>
          {activeNode.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <div class="context-actions">
          <a class="context-return" data-context-return href={`/knowledge/${activeNode.id}/`}>
            返回知识详情
          </a>
        </div>
      </div>

      <div class="panel-block">
        <div class="panel-heading">
          <span>AI API</span>
          <strong>当前页面临时使用</strong>
        </div>
        <form class="api-config" data-api-config>
          <label>
            <span>Endpoint</span>
            <input
              data-api-endpoint
              type="url"
              placeholder="https://api.deepseek.com/chat/completions"
              value="https://api.deepseek.com/chat/completions"
              autocomplete="off"
            />
          </label>
          <label>
            <span>API Key</span>
            <input data-api-key type="password" placeholder="sk-..." autocomplete="off" />
          </label>
          <label>
            <span>Model</span>
            <input data-api-model type="text" value="deepseek-v4-flash" placeholder="deepseek-v4-flash" autocomplete="off" />
          </label>
          <button class="api-start" type="button" data-start-question>确认 API 并生成第一题</button>
        </form>
        <p class="api-note">密钥只保存在当前页面内存中，刷新后清空。浏览器直连 API 需要服务商允许 CORS。</p>
      </div>
    </aside>

    <ChatSurface
      ariaLabel="AI 对话"
      alertData="data-chat-alert"
      statusData="data-chat-status"
      messageData="data-message-list"
      formData="data-answer-form"
      textareaId="answer"
      textareaData="data-answer-input"
      textareaRows={2}
      placeholder="回答当前问题，或输入你想测试的内容。Ctrl + Enter 提交。"
    >
      <div class="chat-toolbar" slot="toolbar">
        <div>
          <span>Session</span>
          <strong data-session-title>{activeNode.title}</strong>
        </div>
        <div class="toolbar-actions">
          <button type="button" data-review-draft-toggle hidden>复习草稿</button>
          <button type="button" data-reset>重新开始</button>
        </div>
      </div>

      <aside class="review-draft-panel" data-review-draft-panel hidden slot="toolbar">
        <div class="review-draft-head">
          <div>
            <span>Review Draft</span>
            <strong data-review-draft-title>待保存的复习记录</strong>
          </div>
          <div class="review-draft-actions">
            <button type="button" data-review-draft-download>下载 JSON</button>
            <button type="button" data-review-draft-clear>清空</button>
            <button type="button" data-review-draft-close>关闭</button>
          </div>
        </div>
        <div class="review-draft-guide">
          <span>使用方式</span>
          <ol>
            <li>复习结束后下载 JSON，文件会包含当前文章已暂存的全部回答记录。</li>
            <li>把下载的 JSON 放到项目根目录后，在终端运行：</li>
          </ol>
          <div class="review-draft-command-row">
            <code data-review-draft-command></code>
            <button type="button" data-review-draft-copy-command aria-label="复制导入命令" title="复制导入命令">
              <Copy size={14} aria-hidden="true" />
            </button>
          </div>
        </div>
        <p data-review-draft-note>复习草稿会暂存在浏览器里，可在结束时一次下载。</p>
        <pre><code data-review-draft-code></code></pre>
      </aside>

      <span data-answer-hint slot="composer-left">
        <Sparkles size={15} aria-hidden="true" />
        <span data-answer-hint-text>填写左侧 API 后，可先生成第一题。</span>
      </span>
    </ChatSurface>
  </section>

  <script define:vars={{ nodesJson }}>
    const nodes = JSON.parse(nodesJson);

    const params = new URLSearchParams(window.location.search);
    const categories = [...new Set(Object.values(nodes).map((node) => node.category))];
    const defaultNodeId = Object.keys(nodes)[0];
    const initialNodeId = nodes[params.get("node")] ? params.get("node") : defaultNodeId;
    const state = {
      node: initialNodeId,
      category: nodes[initialNodeId].category,
      query: "",
      activeQuestion: ""
    };

    const layout = document.querySelector("[data-coach-layout]");
    const coachSidebar = document.querySelector(".coach-sidebar");
    const chatPanel = document.querySelector(".coach-layout > .chat-panel");
    const chatToolbar = document.querySelector(".coach-layout > .chat-panel .chat-toolbar");
    const leftToggle = document.querySelector("[data-toggle-left]");
    const messageList = document.querySelector("[data-message-list]");
    const answerForm = document.querySelector("[data-answer-form]");
    const answerInput = document.querySelector("[data-answer-input]");
    const answerHint = document.querySelector("[data-answer-hint]");
    const answerHintText = document.querySelector("[data-answer-hint-text]");
    const chatAlert = document.querySelector("[data-chat-alert]");
    const chatStatus = document.querySelector("[data-chat-status]");
    const apiEndpointInput = document.querySelector("[data-api-endpoint]");
    const apiKeyInput = document.querySelector("[data-api-key]");
    const apiModelInput = document.querySelector("[data-api-model]");
    const startQuestionButton = document.querySelector("[data-start-question]");
    const categorySelect = document.querySelector("[data-category-select]");
    const nodeList = document.querySelector("[data-node-list]");
    const nodeSearch = document.querySelector("[data-node-search]");
    const nodeCount = document.querySelector("[data-node-count]");
    const nodePicker = document.querySelector("[data-node-picker]");
    const pickerToggle = document.querySelector("[data-toggle-picker]");
    const selectedNodeCard = document.querySelector("[data-selected-node-card]");
    const selectedNodeTitle = document.querySelector("[data-selected-node-title]");
    const reviewDraftToggle = document.querySelector("[data-review-draft-toggle]");
    const reviewDraftPanel = document.querySelector("[data-review-draft-panel]");
    const reviewDraftTitle = document.querySelector("[data-review-draft-title]");
    const reviewDraftCode = document.querySelector("[data-review-draft-code]");
    const reviewDraftDownload = document.querySelector("[data-review-draft-download]");
    const reviewDraftClear = document.querySelector("[data-review-draft-clear]");
    const reviewDraftClose = document.querySelector("[data-review-draft-close]");
    const reviewDraftNote = document.querySelector("[data-review-draft-note]");
    const reviewDraftCommand = document.querySelector("[data-review-draft-command]");
    const reviewDraftCopyCommand = document.querySelector("[data-review-draft-copy-command]");
    const reviewDraftState = {
      raw: "",
      drafts: [],
      updatedAt: ""
    };

    function escapeHtml(value) {
      return value
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function renderInlineMarkdown(text) {
      return escapeHtml(text)
        .replace(/`([^`]+)`/g, "<code>$1</code>")
        .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
        .replace(/\*([^*]+)\*/g, "<em>$1</em>");
    }

    function renderMarkdown(markdown) {
      const lines = markdown.replace(/\r\n/g, "\n").split("\n");
      const html = [];
      let listOpen = false;
      let codeOpen = false;
      let codeLines = [];

      function closeList() {
        if (listOpen) {
          html.push("</ul>");
          listOpen = false;
        }
      }

      function closeCode() {
        if (codeOpen) {
          html.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`);
          codeLines = [];
          codeOpen = false;
        }
      }

      for (const line of lines) {
        if (line.trim().startsWith("```")) {
          if (codeOpen) {
            closeCode();
          } else {
            closeList();
            codeOpen = true;
          }
          continue;
        }

        if (codeOpen) {
          codeLines.push(line);
          continue;
        }

        const trimmed = line.trim();
        if (!trimmed) {
          closeList();
          continue;
        }

        const heading = trimmed.match(/^(#{1,3})\s+(.+)$/);
        if (heading) {
          closeList();
          const level = heading[1].length + 2;
          html.push(`<h${level}>${renderInlineMarkdown(heading[2])}</h${level}>`);
          continue;
        }

        const quote = trimmed.match(/^>\s+(.+)$/);
        if (quote) {
          closeList();
          html.push(`<blockquote>${renderInlineMarkdown(quote[1])}</blockquote>`);
          continue;
        }

        const listItem = trimmed.match(/^[-*•]\s+(.+)$/) || trimmed.match(/^\d+[.)]\s+(.+)$/);
        if (listItem) {
          if (!listOpen) {
            html.push("<ul>");
            listOpen = true;
          }
          html.push(`<li>${renderInlineMarkdown(listItem[1])}</li>`);
          continue;
        }

        closeList();
        html.push(`<p>${renderInlineMarkdown(trimmed)}</p>`);
      }

      closeCode();
      closeList();
      return html.join("");
    }

    function isReviewDraft(value) {
      return value
        && typeof value === "object"
        && ["good", "partial", "wrong", "skipped"].includes(value.performance)
        && Array.isArray(value.questions)
        && Array.isArray(value.suggestedMarks);
    }

    function getQuestionFallback() {
      return state.activeQuestion ? [state.activeQuestion] : [];
    }

    function normalizeReviewDraft(value, fallbackQuestions = getQuestionFallback()) {
      const questions = Array.isArray(value.questions)
        ? value.questions.filter((question) => typeof question === "string" && question.trim()).map((question) => question.trim())
        : [];

      return {
        ...value,
        questions: questions.length ? questions : fallbackQuestions,
        suggestedMarks: value.suggestedMarks.filter((mark) => {
          return mark
            && typeof mark === "object"
            && typeof mark.quote === "string"
            && mark.quote.trim()
            && typeof mark.reason === "string"
            && mark.reason.trim();
        }).map((mark) => ({
          ...mark,
          quote: mark.quote.trim(),
          reason: mark.reason.trim()
        }))
      };
    }

    function extractNextQuestion(text) {
      const normalized = text.replace(/\r\n/g, "\n").trim();
      const markerMatch = normalized.match(/下一题\s*[：:]\s*([\s\S]+)$/);
      const candidate = markerMatch ? markerMatch[1] : normalized;
      const firstLine = candidate
        .split("\n")
        .map((line) => line.trim())
        .find(Boolean);

      return firstLine || "";
    }

    function extractJsonBlocks(text) {
      const drafts = [];
      let cleaned = text.replace(/```(?:json)?\s*([\s\S]*?)```/gi, (full, body) => {
        const trimmed = body.trim();
        try {
          const parsed = JSON.parse(trimmed);
          if (isReviewDraft(parsed)) {
            drafts.push(normalizeReviewDraft(parsed));
            return "";
          }
        } catch {
          // Leave non-JSON or invalid JSON blocks visible in the conversation.
        }
        return full;
      });

      const inlineJsonStart = cleaned.indexOf("{");
      const inlineJsonEnd = cleaned.lastIndexOf("}");
      if (!drafts.length && inlineJsonStart !== -1 && inlineJsonEnd > inlineJsonStart) {
        const candidate = cleaned.slice(inlineJsonStart, inlineJsonEnd + 1).trim();
        try {
          const parsed = JSON.parse(candidate);
          if (isReviewDraft(parsed)) {
            drafts.push(normalizeReviewDraft(parsed));
            cleaned = `${cleaned.slice(0, inlineJsonStart)}${cleaned.slice(inlineJsonEnd + 1)}`;
          }
        } catch {
          // Keep the original text when it is ordinary prose containing braces.
        }
      }

      return {
        cleaned: cleaned.replace(/\n{3,}/g, "\n\n").trim(),
        drafts
      };
    }

    function getReviewDraftFilename() {
      const date = new Date();
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${state.node}-coach-feedback-${year}${month}${day}.json`;
    }

    function buildReviewDraftPayload() {
      return {
        slug: state.node,
        exportedAt: new Date().toISOString(),
        drafts: reviewDraftState.drafts
      };
    }

    function getReviewDraftStorageKey(nodeId = state.node) {
      return `cgweb:coach-review-drafts:${nodeId}`;
    }

    function syncReviewDraftCommand() {
      reviewDraftCommand.textContent = `npm run review:record -- --slug ${state.node} --input ./${getReviewDraftFilename()}`;
    }

    function updateAnswerHint(defaultText) {
      if (!reviewDraftState.drafts.length) {
        answerHintText.textContent = defaultText;
        return;
      }

      answerHintText.textContent = `${defaultText} 已暂存 ${reviewDraftState.drafts.length} 条复习草稿，可在右上角一次下载。`;
    }

    function persistReviewDraftState() {
      if (!reviewDraftState.drafts.length) {
        localStorage.removeItem(getReviewDraftStorageKey());
        return;
      }

      localStorage.setItem(getReviewDraftStorageKey(), JSON.stringify({
        slug: state.node,
        updatedAt: new Date().toISOString(),
        drafts: reviewDraftState.drafts
      }));
    }

    function renderReviewDraftState() {
      const payload = buildReviewDraftPayload();
      reviewDraftState.raw = JSON.stringify(payload, null, 2);
      reviewDraftState.updatedAt = new Date().toLocaleString("zh-CN", { hour12: false });
      reviewDraftCode.textContent = reviewDraftState.raw;
      reviewDraftTitle.textContent = `${nodes[state.node].title} · ${reviewDraftState.drafts.length} 条草稿`;
      syncReviewDraftCommand();
      reviewDraftNote.textContent = `已暂存 ${reviewDraftState.updatedAt} 的 ${reviewDraftState.drafts.length} 条复习记录草稿。导入后会替换当前文章旧记录。`;
      reviewDraftToggle.hidden = false;
      reviewDraftToggle.textContent = `复习草稿 (${reviewDraftState.drafts.length})`;
      syncFixedChatFrame();
    }

    function addReviewDrafts(drafts) {
      reviewDraftState.drafts.push(...drafts);
      persistReviewDraftState();
      renderReviewDraftState();
    }

    function resetReviewDraftUi() {
      reviewDraftState.raw = "";
      reviewDraftState.drafts = [];
      reviewDraftState.updatedAt = "";
      reviewDraftCode.textContent = "";
      syncReviewDraftCommand();
      reviewDraftToggle.hidden = true;
      reviewDraftToggle.textContent = "复习草稿";
      reviewDraftPanel.hidden = true;
    }

    function clearReviewDraft() {
      resetReviewDraftUi();
      localStorage.removeItem(getReviewDraftStorageKey());
      syncFixedChatFrame();
    }

    function restoreReviewDraftState() {
      resetReviewDraftUi();
      const saved = localStorage.getItem(getReviewDraftStorageKey());
      if (!saved) return false;

      try {
        const parsed = JSON.parse(saved);
        const drafts = Array.isArray(parsed.drafts) ? parsed.drafts : [];
        if (!drafts.length || parsed.slug !== state.node) {
          localStorage.removeItem(getReviewDraftStorageKey());
          return false;
        }

        reviewDraftState.drafts = drafts;
        renderReviewDraftState();
        return true;
      } catch {
        localStorage.removeItem(getReviewDraftStorageKey());
        return false;
      }
    }

    function createMessage(role, label, body) {
      const article = document.createElement("article");
      article.className = `message ${role === "user" ? "from-user" : "from-coach"}`;
      article.innerHTML = `<span></span><div class="message-body"></div>`;
      article.querySelector("span").textContent = label;
      article.querySelector(".message-body").innerHTML = renderMarkdown(body);
      return article;
    }

    function setStatus(text = "") {
      chatStatus.textContent = text;
      chatStatus.hidden = !text;
    }

    function showAlert(text = "") {
      chatAlert.textContent = text;
      chatAlert.hidden = !text;
    }

    function clearAlert() {
      showAlert("");
    }

    function resizeAnswerInput() {
      answerInput.style.height = "auto";
      answerInput.style.height = `${Math.min(answerInput.scrollHeight, 180)}px`;
      syncFixedChatFrame();
    }

    function syncFixedChatFrame() {
      if (!layout || !chatPanel || !answerForm || !chatToolbar) return;
      const sidebarWidth = layout.classList.contains("is-left-collapsed") || layout.classList.contains("is-left-shrinking")
        ? 0
        : 260;
      layout.style.setProperty("--coach-sidebar-width", `${sidebarWidth}px`);
      const rect = chatPanel.getBoundingClientRect();
      layout.style.setProperty("--coach-chat-left", `${rect.left}px`);
      layout.style.setProperty("--coach-chat-width", `${rect.width}px`);
      chatPanel.style.paddingTop = `${Math.ceil(chatToolbar.offsetHeight + 30)}px`;
      chatPanel.style.paddingBottom = `${Math.ceil(answerForm.offsetHeight + 42)}px`;
      if (coachSidebar) {
        coachSidebar.style.maxHeight = "";
      }
    }

    function syncFixedChatFrameDuringTransition(duration = 560) {
      const startedAt = performance.now();
      function tick(now) {
        syncFixedChatFrame();
        if (now - startedAt < duration) {
          requestAnimationFrame(tick);
        }
      }
      requestAnimationFrame(tick);
    }

    function scrollLatestMessageIntoView() {
      const latest = messageList?.lastElementChild;
      if (!latest || !answerForm) return;

      requestAnimationFrame(() => {
        syncFixedChatFrame();
        const latestRect = latest.getBoundingClientRect();
        const composerTop = answerForm.getBoundingClientRect().top;
        const safeGap = 24;
        if (latestRect.bottom > composerTop - safeGap) {
          window.scrollBy({
            top: latestRect.bottom - composerTop + safeGap,
            behavior: "smooth"
          });
        }
      });
    }

    function expandLeftPanel() {
      if (!leftToggle || !layout || !layout.classList.contains("is-left-collapsed")) return;
      layout.classList.remove("is-left-collapsing", "is-left-shrinking", "is-left-expanding", "is-left-revealing");
      layout.classList.remove("is-left-collapsed");
      layout.classList.add("is-left-expanding");
      syncFixedChatFrameDuringTransition(820);
      leftToggle.setAttribute("aria-label", "折叠左侧面板");
      leftToggle.setAttribute("aria-expanded", "true");
      window.setTimeout(() => {
        layout.classList.remove("is-left-expanding");
        layout.classList.add("is-left-revealing");
        syncFixedChatFrameDuringTransition(380);
        window.setTimeout(() => layout.classList.remove("is-left-revealing"), 360);
      }, 420);
    }

    function collapseLeftPanel() {
      if (
        !leftToggle ||
        !layout ||
        layout.classList.contains("is-left-collapsed") ||
        layout.classList.contains("is-left-collapsing") ||
        layout.classList.contains("is-left-shrinking")
      ) {
        return;
      }

      layout.classList.remove("is-left-expanding", "is-left-revealing");
      layout.classList.add("is-left-collapsing");
      syncFixedChatFrameDuringTransition(640);
      leftToggle.setAttribute("aria-label", "展开左侧面板");
      leftToggle.setAttribute("aria-expanded", "false");
      window.setTimeout(() => {
        layout.classList.remove("is-left-collapsing");
        layout.classList.add("is-left-shrinking");
      }, 120);
      window.setTimeout(() => {
        layout.classList.remove("is-left-shrinking");
        layout.classList.add("is-left-collapsed");
        syncFixedChatFrame();
      }, 540);
    }

    function renderContext() {
      const node = nodes[state.node];
      document.querySelector("[data-context-description]").textContent = node.description;
      document.querySelector("[data-session-title]").textContent = node.title;

      const contextLink = document.querySelector("[data-context-link]");
      const contextReturn = document.querySelector("[data-context-return]");
      contextLink.textContent = node.title;
      contextLink.href = node.href;
      contextReturn.href = node.href;
      selectedNodeTitle.textContent = node.title;

      document.querySelector("[data-context-tags]").replaceChildren(...node.tags.map((tag) => {
        const span = document.createElement("span");
        span.textContent = tag;
        return span;
      }));

      categorySelect.value = state.category;
      renderNodeList();
    }

    function renderNodeList() {
      const query = state.query.trim().toLowerCase();
      const entries = Object.entries(nodes).filter(([, node]) => {
        const matchesCategory = state.category === "all" || node.category === state.category;
        const searchable = `${node.title} ${node.description} ${node.category} ${node.tags.join(" ")}`.toLowerCase();
        const matchesQuery = !query || searchable.includes(query);
        return matchesCategory && matchesQuery;
      });

      nodeCount.textContent = `${entries.length} 篇可选`;
      nodeList.replaceChildren(...entries.map(([id, node]) => {
        const button = document.createElement("button");
        button.type = "button";
        button.dataset.node = id;
        button.classList.toggle("is-active", id === state.node);
        button.innerHTML = "<span></span>";
        button.querySelector("span").textContent = node.title;
        button.addEventListener("click", () => selectNode(id));
        return button;
      }));

      if (!entries.length) {
        const empty = document.createElement("p");
        empty.className = "node-empty";
        empty.textContent = "没有匹配的文章";
        nodeList.replaceChildren(empty);
      }
    }

    function setNodePickerExpanded(expanded) {
      nodePicker.classList.toggle("is-collapsed", !expanded);
      pickerToggle.setAttribute("aria-expanded", String(expanded));
      pickerToggle.setAttribute("aria-label", expanded ? "收起文章选择" : "展开文章选择");
    }

    function resetSession() {
      renderContext();
      messageList.replaceChildren();
      restoreReviewDraftState();
      state.activeQuestion = "";
      clearAlert();
      setStatus("");
      answerInput.value = "";
      resizeAnswerInput();
      updateAnswerHint("填写左侧 API 后，可先生成第一题。");
    }

    function confirmDiscardReviewDrafts(actionText) {
      if (!reviewDraftState.drafts.length) return true;
      return window.confirm(`当前文章还有 ${reviewDraftState.drafts.length} 条未下载的复习草稿。${actionText}会保留浏览器暂存，但当前对话会重置；建议先下载 JSON。仍要继续吗？`);
    }

    function normalizeEndpoint(value) {
      const trimmed = value.trim().replace(/\/+$/, "");
      if (!trimmed) return "";
      if (trimmed.endsWith("/chat/completions")) return trimmed;
      if (trimmed.endsWith("/openai")) return `${trimmed}/chat/completions`;
      if (trimmed.endsWith("/v1")) return `${trimmed}/chat/completions`;
      return `${trimmed}/v1/chat/completions`;
    }

    function hasApiConfig() {
      return apiEndpointInput.value.trim() && apiKeyInput.value.trim() && apiModelInput.value.trim();
    }

    function focusMissingApiField() {
      if (!apiEndpointInput.value.trim()) {
        apiEndpointInput.focus();
        return;
      }
      if (!apiKeyInput.value.trim()) {
        apiKeyInput.focus();
        return;
      }
      if (!apiModelInput.value.trim()) {
        apiModelInput.focus();
      }
    }

    function renderApiRequired() {
      showAlert("请先填写 Endpoint、API Key 和 Model，然后点击“确认 API 并生成第一题”。");
      answerHintText.textContent = "补全左侧 API 信息后再开始。";
      focusMissingApiField();
    }

    function buildKnowledgeContext(node) {
      return [
        `标题：${node.title}`,
        `方向：${node.track}`,
        `分类：${node.category}`,
        `难度：${node.level}`,
        `预计学习时间：${node.minutes} 分钟`,
        `前置知识：${node.prerequisites.length ? node.prerequisites.join("、") : "无"}`,
        `标签：${node.tags.length ? node.tags.join("、") : "无"}`,
        `简介：${node.description}`,
        "正文：",
        node.body
      ].join("\n");
    }

    function parseApiError(status, detail) {
      let message = detail.slice(0, 220);
      try {
        const parsed = JSON.parse(detail);
        message = parsed?.error?.message || message;
      } catch {
        // Keep the raw preview when the provider does not return JSON.
      }

      if (status === 401 || status === 403) {
        return `API 认证失败：请检查 API Key 是否有效，或当前 Key 是否有权限调用这个模型。${message}`;
      }
      if (status === 404) {
        return `模型或接口不存在：请检查 Endpoint 和 Model 名称。${message}`;
      }
      if (status === 429) {
        return `API 配额或频率受限：当前 Key 可能已经达到免费额度、频率上限或项目额度限制。${message}`;
      }
      if (status === 503) {
        return `模型服务繁忙：服务商当前负载较高，可以稍后重试，或切换到其他可用模型。${message}`;
      }
      return `API 请求失败：${status} ${message}`;
    }

    async function requestAiFeedback(node, answer, mode = "feedback") {
      const endpoint = normalizeEndpoint(apiEndpointInput.value);
      const knowledgeContext = buildKnowledgeContext(node);
      const modeInstruction = mode === "question"
        ? "请提出第一道测试题。只输出一个问题和一句答题关注点，不要给答案。"
        : [
          "请先反馈用户回答，再继续提出下一道测试题。输出里必须包含“下一题：”。",
          "如果用户回答存在遗漏、模糊或错误，请额外给出“复习记录草稿”代码块。",
          "复习记录草稿必须是 JSON，字段包含 performance、score、coachSummary、questions、suggestedMarks。",
          "questions 必须包含当前问题原文，不能输出空数组。",
          "performance 只能是 good、partial、wrong、skipped。",
          "suggestedMarks 中每一项都必须包含 quote、reason、type、severity。",
          "quote 必须尽量摘取当前文章正文中的原句；reason 用一句话说明用户哪里漏答、误解或值得回看。",
          "type 只能是 mistake、unclear、note，severity 只能是 low、medium、high。",
          "不要输出缺少 quote 或 reason 的 suggestedMarks；没有可标注原句时输出空数组。",
          "如果回答基本掌握且不需要标注，suggestedMarks 输出空数组。"
        ].join("\n");
      const response = await fetch(endpoint, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${apiKeyInput.value.trim()}`
        },
        body: JSON.stringify({
          model: apiModelInput.value.trim(),
          temperature: 0.2,
          messages: [
            {
              role: "system",
              content: [
                "你是一个面向 UE5 游戏开发学习的知识点测试教练。",
                "你会收到一段知识库上下文和用户输入，请严格基于上下文处理，不要编造上下文之外的细节。",
                "用户开始测试时，给出一个围绕当前知识点的问题，并附一句答题关注点。",
                "用户提交回答后，先指出命中的关键点、遗漏点和改进方向，然后自动给出下一题。",
                "不要评分，不要索要个人信息，不要输出与当前知识点无关的内容。",
                "输出应简洁、适合聊天窗口阅读。"
              ].join("\n")
            },
            {
              role: "user",
              content: [
                "知识库上下文：",
                knowledgeContext,
                "当前问题：",
                mode === "feedback" ? state.activeQuestion || "未记录" : "请生成第一题",
                "用户输入：",
                answer,
                "任务要求：",
                modeInstruction
              ].join("\n\n")
            }
          ]
        })
      });

      if (!response.ok) {
        const detail = await response.text();
        throw new Error(parseApiError(response.status, detail));
      }

      const data = await response.json();
      const content = data?.choices?.[0]?.message?.content;
      if (!content) {
        throw new Error("API 返回中没有可用的 message.content。");
      }
      return content.trim();
    }

    async function generateFirstQuestion() {
      const node = nodes[state.node];
      if (!hasApiConfig()) {
        renderApiRequired();
        return;
      }

      clearAlert();
      setStatus(`正在基于「${node.title}」生成第一题...`);
      startQuestionButton.disabled = true;
      answerForm.querySelector("button").disabled = true;

      try {
        const question = await requestAiFeedback(
          node,
          "开始测试，请提出第一道题。",
          "question"
        );
        state.activeQuestion = extractNextQuestion(question);
        messageList.append(createMessage("coach", "AI Coach", question));
        scrollLatestMessageIntoView();
        updateAnswerHint("回答上方题目后提交，获取反馈并进入下一题。");
        collapseLeftPanel();
        answerInput.focus();
      } catch (error) {
        showAlert(`${error.message} 如果浏览器提示跨域或请求没有到达服务商，说明该服务商不允许纯前端直连，需要后续增加代理层。`);
      } finally {
        setStatus("");
        startQuestionButton.disabled = false;
        answerForm.querySelector("button").disabled = false;
      }
    }

    answerForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const answer = answerInput.value.trim();
      if (!answer) {
        answerHintText.textContent = "先写下内容，再提交。";
        answerInput.focus();
        return;
      }

      const node = nodes[state.node];
      if (!hasApiConfig()) {
        renderApiRequired();
        return;
      }

      clearAlert();
      messageList.append(createMessage("user", "DaydreamerH", answer));
      answerInput.value = "";
      resizeAnswerInput();
      scrollLatestMessageIntoView();
      setStatus("正在分析回答并准备下一题...");
      answerForm.querySelector("button").disabled = true;
      startQuestionButton.disabled = true;

      try {
        const aiFeedback = await requestAiFeedback(node, answer);
        const { cleaned, drafts } = extractJsonBlocks(aiFeedback);
        if (drafts.length) {
          addReviewDrafts(drafts);
        }
        messageList.append(createMessage("coach", "AI Coach", cleaned || "已整理本次复习记录。"));
        state.activeQuestion = extractNextQuestion(cleaned) || state.activeQuestion;
        scrollLatestMessageIntoView();
      } catch (error) {
        showAlert(`${error.message} 如果浏览器提示跨域或请求没有到达服务商，说明该服务商不允许纯前端直连，需要后续增加代理层。`);
      } finally {
        setStatus("");
        answerForm.querySelector("button").disabled = false;
        startQuestionButton.disabled = false;
      }

      updateAnswerHint("继续回答最新问题。Ctrl + Enter 提交。");
    });

    answerInput.addEventListener("input", resizeAnswerInput);

    answerInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && event.ctrlKey) {
        event.preventDefault();
        answerForm.requestSubmit();
      }
    });

    startQuestionButton.addEventListener("click", generateFirstQuestion);

    async function restartSession() {
      if (!confirmDiscardReviewDrafts("重新开始")) return;
      resetSession();
      await generateFirstQuestion();
    }

    function selectNode(id) {
      if (id === state.node) return;
      if (!confirmDiscardReviewDrafts("切换文章")) return;
      state.node = id;
      state.category = nodes[id].category;
      state.query = "";
      nodeSearch.value = "";
      const url = new URL(window.location.href);
      url.searchParams.set("node", state.node);
      history.replaceState(null, "", url);
      resetSession();
      setNodePickerExpanded(false);
    }

    function updateCategoryFilter() {
      state.category = categorySelect.value;
      renderNodeList();
    }

    categorySelect.addEventListener("change", updateCategoryFilter);
    categorySelect.addEventListener("input", updateCategoryFilter);

    nodeSearch.addEventListener("input", () => {
      state.query = nodeSearch.value;
      renderNodeList();
    });
    nodeSearch.addEventListener("change", () => {
      state.query = nodeSearch.value;
      renderNodeList();
    });
    pickerToggle.addEventListener("click", () => {
      setNodePickerExpanded(nodePicker.classList.contains("is-collapsed"));
    });
    selectedNodeCard.addEventListener("click", () => {
      setNodePickerExpanded(true);
    });

    reviewDraftToggle.addEventListener("click", () => {
      reviewDraftPanel.hidden = !reviewDraftPanel.hidden;
      syncFixedChatFrame();
    });

    reviewDraftClose.addEventListener("click", () => {
      reviewDraftPanel.hidden = true;
      syncFixedChatFrame();
    });

    reviewDraftCopyCommand.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(reviewDraftCommand.textContent);
        reviewDraftNote.textContent = "已复制导入命令。确认 JSON 位于项目根目录后即可运行。";
      } catch {
        reviewDraftNote.textContent = "复制命令失败，请手动选中上方命令复制。";
      }
    });

    reviewDraftDownload.addEventListener("click", () => {
      if (!reviewDraftState.raw) return;
      const blob = new Blob([`${reviewDraftState.raw}\n`], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement("a");
      anchor.href = url;
      anchor.download = getReviewDraftFilename();
      document.body.append(anchor);
      anchor.click();
      anchor.remove();
      URL.revokeObjectURL(url);
      reviewDraftNote.textContent = `已下载 ${getReviewDraftFilename()}。把它放到项目根目录，运行上方命令导入后再提交。`;
    });

    reviewDraftClear.addEventListener("click", () => {
      if (!reviewDraftState.drafts.length) return;
      if (!window.confirm(`确定清空当前文章的 ${reviewDraftState.drafts.length} 条复习草稿吗？这只会清空浏览器暂存，不会修改项目文件。`)) return;
      clearReviewDraft();
      answerHintText.textContent = "复习草稿已清空。可以继续当前对话，或重新开始。";
    });

    leftToggle.addEventListener("click", () => {
      if (layout.classList.contains("is-left-collapsed")) {
        expandLeftPanel();
        return;
      }

      collapseLeftPanel();
    });

    window.addEventListener("resize", syncFixedChatFrame);
    document.querySelector("[data-reset]").addEventListener("click", restartSession);
    resetSession();
    resizeAnswerInput();
    syncFixedChatFrame();
  </script>
</BaseLayout>
