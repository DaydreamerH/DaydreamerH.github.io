---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { ChevronDown, ChevronUp, PanelLeftClose, PanelLeftOpen } from "@lucide/astro";
import { getCategoryLabel, getLevelLabel } from "../data/navigation";

const docs = (await getCollection("knowledge"))
  .filter((item) => item.data.status === "ready" && item.data.published !== false)
  .sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    const dateA = a.data.date ? Date.parse(a.data.date) : 0;
    const dateB = b.data.date ? Date.parse(b.data.date) : 0;
    if (dateA !== dateB) return dateB - dateA;
    return a.data.title.localeCompare(b.data.title, "zh-Hans-CN");
  });

const knowledgeNodes = docs.map((doc) => ({
  id: doc.slug,
  category: getCategoryLabel(doc.data.category),
  href: `/knowledge/${doc.slug}/`,
  title: doc.data.title,
  description: doc.data.description,
  track: doc.data.track,
  level: getLevelLabel(doc.data.level),
  minutes: doc.data.minutes,
  prerequisites: doc.data.prerequisites,
  tags: doc.data.tags,
  body: doc.body.trim()
}));
const activeNode = knowledgeNodes[0];
const categories = [...new Set(knowledgeNodes.map((node) => node.category))];
const nodesJson = JSON.stringify(Object.fromEntries(knowledgeNodes.map((node) => [node.id, node])));
---

<BaseLayout title="AI Coach" description="DaydreamerH 的知识点提问工作区。">
  <section class="coach-layout compact" data-coach-layout aria-label="AI Coach 知识点提问">
    <aside class="coach-sidebar">
      <div class="panel-block">
        <div class="panel-heading panel-heading-row">
          <div>
            <span>测试目标与上下文</span>
            <strong><a data-context-link href={`/knowledge/${activeNode.id}/`}>{activeNode.title}</a></strong>
          </div>
          <button class="side-toggle" type="button" data-toggle-left aria-label="折叠左侧面板" aria-expanded="true">
            <PanelLeftClose class="toggle-icon icon-collapse" size={18} aria-hidden="true" />
            <PanelLeftOpen class="toggle-icon icon-expand" size={18} aria-hidden="true" />
          </button>
        </div>
        <div class="node-picker is-collapsed" data-node-picker>
          <div class="node-picker-head">
            <span data-node-count></span>
            <button
              class="picker-toggle"
              type="button"
              data-toggle-picker
              aria-label="展开文章选择"
              aria-expanded="false"
            >
              <ChevronDown class="toggle-icon icon-expand" size={17} aria-hidden="true" />
              <ChevronUp class="toggle-icon icon-collapse" size={17} aria-hidden="true" />
            </button>
          </div>
          <button class="selected-node-card" type="button" data-selected-node-card>
            <span data-selected-node-title>{activeNode.title}</span>
          </button>
          <div class="node-picker-body" data-node-picker-body>
            <label class="select-field compact-select">
              <span>分类</span>
              <select data-category-select>
                <option value="all">全部分类</option>
                {categories.map((category) => (
                  <option value={category} selected={category === activeNode.category}>{category}</option>
                ))}
              </select>
            </label>
            <label class="search-field coach-search">
              <span>搜索文章</span>
              <input data-node-search type="search" placeholder="输入标题、标签或分类..." autocomplete="off" />
            </label>
            <div class="node-list" data-node-list>
              {knowledgeNodes
                .filter((node) => node.category === activeNode.category)
                .map((node, index) => (
                <button class={index === 0 ? "is-active" : ""} data-node={node.id} type="button">
                  <span>{node.title}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
        <p class="muted-copy" data-context-description>{activeNode.description}</p>
        <div class="tag-row" data-context-tags>
          {activeNode.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <div class="context-actions">
          <a class="context-return" data-context-return href={`/knowledge/${activeNode.id}/`}>
            返回知识详情
          </a>
          <a class="context-return" href="/knowledge/">返回知识库</a>
        </div>
      </div>

      <div class="panel-block">
        <div class="panel-heading">
          <span>AI API</span>
          <strong>当前页面临时使用</strong>
        </div>
        <form class="api-config" data-api-config>
          <label>
            <span>Endpoint</span>
            <input
              data-api-endpoint
              type="url"
              placeholder="https://api.deepseek.com/chat/completions"
              value="https://api.deepseek.com/chat/completions"
              autocomplete="off"
            />
          </label>
          <label>
            <span>API Key</span>
            <input data-api-key type="password" placeholder="sk-..." autocomplete="off" />
          </label>
          <label>
            <span>Model</span>
            <input data-api-model type="text" value="deepseek-v4-flash" placeholder="deepseek-v4-flash" autocomplete="off" />
          </label>
          <button class="api-start" type="button" data-start-question>确认 API 并生成第一题</button>
        </form>
        <p class="api-note">密钥只保存在当前页面内存中，刷新后清空。浏览器直连 API 需要服务商允许 CORS。</p>
      </div>
    </aside>

    <section class="chat-panel">
      <div class="chat-toolbar">
        <div>
          <span>Session</span>
          <strong data-session-title>{activeNode.title}</strong>
        </div>
        <div class="toolbar-actions">
          <button type="button" data-reset>重新开始</button>
        </div>
      </div>

      <div class="chat-alert" data-chat-alert hidden></div>
      <div class="chat-status" data-chat-status hidden></div>
      <div class="message-list" aria-label="AI 对话" data-message-list></div>

      <form class="answer-box" data-answer-form>
        <label for="answer">你的输入</label>
        <textarea id="answer" rows="4" data-answer-input placeholder="回答当前问题，或输入你想测试的内容。Ctrl + Enter 提交。"></textarea>
        <div>
          <span data-answer-hint>填写左侧 API 后，可先生成第一题。</span>
          <button type="submit">提交</button>
        </div>
      </form>
    </section>
  </section>

  <script define:vars={{ nodesJson }}>
    const nodes = JSON.parse(nodesJson);

    const params = new URLSearchParams(window.location.search);
    const categories = [...new Set(Object.values(nodes).map((node) => node.category))];
    const defaultNodeId = Object.keys(nodes)[0];
    const initialNodeId = nodes[params.get("node")] ? params.get("node") : defaultNodeId;
    const state = {
      node: initialNodeId,
      category: nodes[initialNodeId].category,
      query: ""
    };

    const layout = document.querySelector("[data-coach-layout]");
    const messageList = document.querySelector("[data-message-list]");
    const answerForm = document.querySelector("[data-answer-form]");
    const answerInput = document.querySelector("[data-answer-input]");
    const answerHint = document.querySelector("[data-answer-hint]");
    const chatAlert = document.querySelector("[data-chat-alert]");
    const chatStatus = document.querySelector("[data-chat-status]");
    const apiEndpointInput = document.querySelector("[data-api-endpoint]");
    const apiKeyInput = document.querySelector("[data-api-key]");
    const apiModelInput = document.querySelector("[data-api-model]");
    const startQuestionButton = document.querySelector("[data-start-question]");
    const categorySelect = document.querySelector("[data-category-select]");
    const nodeList = document.querySelector("[data-node-list]");
    const nodeSearch = document.querySelector("[data-node-search]");
    const nodeCount = document.querySelector("[data-node-count]");
    const nodePicker = document.querySelector("[data-node-picker]");
    const pickerToggle = document.querySelector("[data-toggle-picker]");
    const selectedNodeCard = document.querySelector("[data-selected-node-card]");
    const selectedNodeTitle = document.querySelector("[data-selected-node-title]");

    function escapeHtml(value) {
      return value
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function renderInlineMarkdown(text) {
      return escapeHtml(text)
        .replace(/`([^`]+)`/g, "<code>$1</code>")
        .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
        .replace(/\*([^*]+)\*/g, "<em>$1</em>");
    }

    function renderMarkdown(markdown) {
      const lines = markdown.replace(/\r\n/g, "\n").split("\n");
      const html = [];
      let listOpen = false;
      let codeOpen = false;
      let codeLines = [];

      function closeList() {
        if (listOpen) {
          html.push("</ul>");
          listOpen = false;
        }
      }

      function closeCode() {
        if (codeOpen) {
          html.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`);
          codeLines = [];
          codeOpen = false;
        }
      }

      for (const line of lines) {
        if (line.trim().startsWith("```")) {
          if (codeOpen) {
            closeCode();
          } else {
            closeList();
            codeOpen = true;
          }
          continue;
        }

        if (codeOpen) {
          codeLines.push(line);
          continue;
        }

        const trimmed = line.trim();
        if (!trimmed) {
          closeList();
          continue;
        }

        const heading = trimmed.match(/^(#{1,3})\s+(.+)$/);
        if (heading) {
          closeList();
          const level = heading[1].length + 2;
          html.push(`<h${level}>${renderInlineMarkdown(heading[2])}</h${level}>`);
          continue;
        }

        const quote = trimmed.match(/^>\s+(.+)$/);
        if (quote) {
          closeList();
          html.push(`<blockquote>${renderInlineMarkdown(quote[1])}</blockquote>`);
          continue;
        }

        const listItem = trimmed.match(/^[-*•]\s+(.+)$/) || trimmed.match(/^\d+[.)]\s+(.+)$/);
        if (listItem) {
          if (!listOpen) {
            html.push("<ul>");
            listOpen = true;
          }
          html.push(`<li>${renderInlineMarkdown(listItem[1])}</li>`);
          continue;
        }

        closeList();
        html.push(`<p>${renderInlineMarkdown(trimmed)}</p>`);
      }

      closeCode();
      closeList();
      return html.join("");
    }

    function createMessage(role, label, body) {
      const article = document.createElement("article");
      article.className = `message ${role === "user" ? "from-user" : "from-coach"}`;
      article.innerHTML = `<span></span><div class="message-body"></div>`;
      article.querySelector("span").textContent = label;
      article.querySelector(".message-body").innerHTML = renderMarkdown(body);
      return article;
    }

    function setStatus(text = "") {
      chatStatus.textContent = text;
      chatStatus.hidden = !text;
    }

    function showAlert(text = "") {
      chatAlert.textContent = text;
      chatAlert.hidden = !text;
    }

    function clearAlert() {
      showAlert("");
    }

    function renderContext() {
      const node = nodes[state.node];
      document.querySelector("[data-context-description]").textContent = node.description;
      document.querySelector("[data-session-title]").textContent = node.title;

      const contextLink = document.querySelector("[data-context-link]");
      const contextReturn = document.querySelector("[data-context-return]");
      contextLink.textContent = node.title;
      contextLink.href = node.href;
      contextReturn.href = node.href;
      selectedNodeTitle.textContent = node.title;

      document.querySelector("[data-context-tags]").replaceChildren(...node.tags.map((tag) => {
        const span = document.createElement("span");
        span.textContent = tag;
        return span;
      }));

      categorySelect.value = state.category;
      renderNodeList();
    }

    function renderNodeList() {
      const query = state.query.trim().toLowerCase();
      const entries = Object.entries(nodes).filter(([, node]) => {
        const matchesCategory = state.category === "all" || node.category === state.category;
        const searchable = `${node.title} ${node.description} ${node.category} ${node.tags.join(" ")}`.toLowerCase();
        const matchesQuery = !query || searchable.includes(query);
        return matchesCategory && matchesQuery;
      });

      nodeCount.textContent = `${entries.length} 篇可选`;
      nodeList.replaceChildren(...entries.map(([id, node]) => {
        const button = document.createElement("button");
        button.type = "button";
        button.dataset.node = id;
        button.classList.toggle("is-active", id === state.node);
        button.innerHTML = "<span></span>";
        button.querySelector("span").textContent = node.title;
        button.addEventListener("click", () => selectNode(id));
        return button;
      }));

      if (!entries.length) {
        const empty = document.createElement("p");
        empty.className = "node-empty";
        empty.textContent = "没有匹配的文章";
        nodeList.replaceChildren(empty);
      }
    }

    function setNodePickerExpanded(expanded) {
      nodePicker.classList.toggle("is-collapsed", !expanded);
      pickerToggle.setAttribute("aria-expanded", String(expanded));
      pickerToggle.setAttribute("aria-label", expanded ? "收起文章选择" : "展开文章选择");
    }

    function resetSession() {
      renderContext();
      messageList.replaceChildren();
      clearAlert();
      setStatus("");
      answerInput.value = "";
      answerHint.textContent = "填写左侧 API 后，可先生成第一题。";
    }

    function normalizeEndpoint(value) {
      const trimmed = value.trim().replace(/\/+$/, "");
      if (!trimmed) return "";
      if (trimmed.endsWith("/chat/completions")) return trimmed;
      if (trimmed.endsWith("/openai")) return `${trimmed}/chat/completions`;
      if (trimmed.endsWith("/v1")) return `${trimmed}/chat/completions`;
      return `${trimmed}/v1/chat/completions`;
    }

    function hasApiConfig() {
      return apiEndpointInput.value.trim() && apiKeyInput.value.trim() && apiModelInput.value.trim();
    }

    function focusMissingApiField() {
      if (!apiEndpointInput.value.trim()) {
        apiEndpointInput.focus();
        return;
      }
      if (!apiKeyInput.value.trim()) {
        apiKeyInput.focus();
        return;
      }
      if (!apiModelInput.value.trim()) {
        apiModelInput.focus();
      }
    }

    function renderApiRequired() {
      showAlert("请先填写 Endpoint、API Key 和 Model，然后点击“确认 API 并生成第一题”。");
      answerHint.textContent = "补全左侧 API 信息后再开始。";
      focusMissingApiField();
    }

    function buildKnowledgeContext(node) {
      return [
        `标题：${node.title}`,
        `方向：${node.track}`,
        `分类：${node.category}`,
        `难度：${node.level}`,
        `预计学习时间：${node.minutes} 分钟`,
        `前置知识：${node.prerequisites.length ? node.prerequisites.join("、") : "无"}`,
        `标签：${node.tags.length ? node.tags.join("、") : "无"}`,
        `简介：${node.description}`,
        "正文：",
        node.body
      ].join("\n");
    }

    function parseApiError(status, detail) {
      let message = detail.slice(0, 220);
      try {
        const parsed = JSON.parse(detail);
        message = parsed?.error?.message || message;
      } catch {
        // Keep the raw preview when the provider does not return JSON.
      }

      if (status === 401 || status === 403) {
        return `API 认证失败：请检查 API Key 是否有效，或当前 Key 是否有权限调用这个模型。${message}`;
      }
      if (status === 404) {
        return `模型或接口不存在：请检查 Endpoint 和 Model 名称。${message}`;
      }
      if (status === 429) {
        return `API 配额或频率受限：当前 Key 可能已经达到免费额度、频率上限或项目额度限制。${message}`;
      }
      if (status === 503) {
        return `模型服务繁忙：服务商当前负载较高，可以稍后重试，或切换到其他可用模型。${message}`;
      }
      return `API 请求失败：${status} ${message}`;
    }

    async function requestAiFeedback(node, answer, mode = "feedback") {
      const endpoint = normalizeEndpoint(apiEndpointInput.value);
      const knowledgeContext = buildKnowledgeContext(node);
      const modeInstruction = mode === "question"
        ? "请提出第一道测试题。只输出一个问题和一句答题关注点，不要给答案。"
        : "请先用 2 到 4 个短要点反馈用户回答，再继续提出下一道测试题。输出里必须包含“下一题：”。";
      const response = await fetch(endpoint, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${apiKeyInput.value.trim()}`
        },
        body: JSON.stringify({
          model: apiModelInput.value.trim(),
          temperature: 0.2,
          messages: [
            {
              role: "system",
              content: [
                "你是一个面向 UE5 游戏开发学习的知识点测试教练。",
                "你会收到一段知识库上下文和用户输入，请严格基于上下文处理，不要编造上下文之外的细节。",
                "用户开始测试时，给出一个围绕当前知识点的问题，并附一句答题关注点。",
                "用户提交回答后，先指出命中的关键点、遗漏点和改进方向，然后自动给出下一题。",
                "不要评分，不要索要个人信息，不要输出与当前知识点无关的内容。",
                "输出应简洁、适合聊天窗口阅读。"
              ].join("\n")
            },
            {
              role: "user",
              content: [
                "知识库上下文：",
                knowledgeContext,
                "用户输入：",
                answer,
                "任务要求：",
                modeInstruction
              ].join("\n\n")
            }
          ]
        })
      });

      if (!response.ok) {
        const detail = await response.text();
        throw new Error(parseApiError(response.status, detail));
      }

      const data = await response.json();
      const content = data?.choices?.[0]?.message?.content;
      if (!content) {
        throw new Error("API 返回中没有可用的 message.content。");
      }
      return content.trim();
    }

    async function generateFirstQuestion() {
      const node = nodes[state.node];
      if (!hasApiConfig()) {
        renderApiRequired();
        return;
      }

      clearAlert();
      setStatus(`正在基于「${node.title}」生成第一题...`);
      startQuestionButton.disabled = true;
      answerForm.querySelector("button").disabled = true;

      try {
        const question = await requestAiFeedback(
          node,
          "开始测试，请提出第一道题。",
          "question"
        );
        messageList.append(createMessage("coach", "AI Coach", question));
        answerHint.textContent = "回答上方题目后提交，获取反馈并进入下一题。";
        answerInput.focus();
      } catch (error) {
        showAlert(`${error.message} 如果浏览器提示跨域或请求没有到达服务商，说明该服务商不允许纯前端直连，需要后续增加代理层。`);
      } finally {
        setStatus("");
        startQuestionButton.disabled = false;
        answerForm.querySelector("button").disabled = false;
        messageList.scrollTop = messageList.scrollHeight;
      }
    }

    answerForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const answer = answerInput.value.trim();
      if (!answer) {
        answerHint.textContent = "先写下你的输入，再提交。";
        answerInput.focus();
        return;
      }

      const node = nodes[state.node];
      if (!hasApiConfig()) {
        renderApiRequired();
        return;
      }

      clearAlert();
      messageList.append(createMessage("user", "DaydreamerH", answer));
      setStatus("正在分析回答并准备下一题...");
      answerForm.querySelector("button").disabled = true;
      startQuestionButton.disabled = true;

      try {
        const aiFeedback = await requestAiFeedback(node, answer);
        messageList.append(createMessage("coach", "AI Coach", aiFeedback));
      } catch (error) {
        showAlert(`${error.message} 如果浏览器提示跨域或请求没有到达服务商，说明该服务商不允许纯前端直连，需要后续增加代理层。`);
      } finally {
        setStatus("");
        answerForm.querySelector("button").disabled = false;
        startQuestionButton.disabled = false;
      }

      answerInput.value = "";
      answerHint.textContent = "继续回答最新问题。Ctrl + Enter 提交。";
      messageList.scrollTop = messageList.scrollHeight;
    });

    answerInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && event.ctrlKey) {
        event.preventDefault();
        answerForm.requestSubmit();
      }
    });

    startQuestionButton.addEventListener("click", generateFirstQuestion);

    function selectNode(id) {
      state.node = id;
      state.category = nodes[id].category;
      state.query = "";
      nodeSearch.value = "";
      const url = new URL(window.location.href);
      url.searchParams.set("node", state.node);
      history.replaceState(null, "", url);
      resetSession();
      setNodePickerExpanded(false);
    }

    function updateCategoryFilter() {
      state.category = categorySelect.value;
      renderNodeList();
    }

    categorySelect.addEventListener("change", updateCategoryFilter);
    categorySelect.addEventListener("input", updateCategoryFilter);

    nodeSearch.addEventListener("input", () => {
      state.query = nodeSearch.value;
      renderNodeList();
    });
    nodeSearch.addEventListener("change", () => {
      state.query = nodeSearch.value;
      renderNodeList();
    });
    pickerToggle.addEventListener("click", () => {
      setNodePickerExpanded(nodePicker.classList.contains("is-collapsed"));
    });
    selectedNodeCard.addEventListener("click", () => {
      setNodePickerExpanded(true);
    });

    document.querySelector("[data-toggle-left]").addEventListener("click", (event) => {
      const willExpand = layout.classList.contains("is-left-collapsed");
      layout.classList.remove("is-left-collapsing", "is-left-expanding");

      if (willExpand) {
        layout.classList.remove("is-left-collapsed");
        layout.classList.add("is-left-expanding");
        event.currentTarget.setAttribute("aria-label", "折叠左侧面板");
        event.currentTarget.setAttribute("aria-expanded", "true");
        window.setTimeout(() => layout.classList.remove("is-left-expanding"), 360);
        return;
      }

      layout.classList.add("is-left-collapsing");
      event.currentTarget.setAttribute("aria-label", "展开左侧面板");
      event.currentTarget.setAttribute("aria-expanded", "false");
      window.setTimeout(() => {
        layout.classList.remove("is-left-collapsing");
        layout.classList.add("is-left-collapsed");
      }, 180);
    });

    document.querySelector("[data-reset]").addEventListener("click", resetSession);
    resetSession();
  </script>
</BaseLayout>
