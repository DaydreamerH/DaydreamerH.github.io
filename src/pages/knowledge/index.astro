---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getCategoryLabel, getLevelLabel } from "../../data/navigation";

const docs = (await getCollection("knowledge"))
  .filter((item) => item.data.status === "ready" && item.data.published !== false)
  .sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    const dateA = a.data.date ? Date.parse(a.data.date) : 0;
    const dateB = b.data.date ? Date.parse(b.data.date) : 0;
    if (dateA !== dateB) return dateB - dateA;
    return a.data.title.localeCompare(b.data.title, "zh-Hans-CN");
  });

const categories = [...new Set(docs.map((doc) => doc.data.category))]
  .sort((a, b) => getCategoryLabel(a).localeCompare(getCategoryLabel(b), "zh-Hans-CN"));
---

<BaseLayout title="知识库" description="DaydreamerH 的游戏开发知识库。">
  <section class="toolbar" aria-label="知识库筛选">
    <label class="search-field">
      <span>搜索</span>
      <input id="knowledge-search" type="search" placeholder="输入 C++、UObject、Gameplay..." />
    </label>
    <label class="select-field">
      <span>分类</span>
      <select id="category-filter">
        <option value="all">全部分类</option>
        {categories.map((category) => (
          <option value={category}>{getCategoryLabel(category)}</option>
        ))}
      </select>
    </label>
  </section>

  <section class="knowledge-grid" id="knowledge-grid">
    {docs.map((doc) => (
      <article
        class="knowledge-card"
        data-title={doc.data.title.toLowerCase()}
        data-tags={doc.data.tags.join(" ").toLowerCase()}
        data-category={doc.data.category}
      >
        <div class="card-meta">
          <span class="pill">{getCategoryLabel(doc.data.category)}</span>
          <span>{getLevelLabel(doc.data.level)} · {doc.data.minutes} min</span>
        </div>
        <h2><a href={`/knowledge/${doc.slug}/`}>{doc.data.title}</a></h2>
        <p>{doc.data.description}</p>
        <div class="tag-row">
          {doc.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </article>
    ))}
  </section>

  <p class="empty-state" id="empty-state" hidden>没有匹配的知识点。</p>

  <script>
    const searchInput = document.querySelector("#knowledge-search");
    const categoryFilter = document.querySelector("#category-filter");
    const cards = Array.from(document.querySelectorAll(".knowledge-card"));
    const emptyState = document.querySelector("#empty-state");

    function applyFilters() {
      const query = searchInput.value.trim().toLowerCase();
      const category = categoryFilter.value;
      let visible = 0;

      for (const card of cards) {
        const text = `${card.dataset.title} ${card.dataset.tags}`;
        const matchesQuery = !query || text.includes(query);
        const matchesCategory = category === "all" || card.dataset.category === category;
        const show = matchesQuery && matchesCategory;
        card.hidden = !show;
        if (show) visible += 1;
      }

      emptyState.hidden = visible !== 0;
    }

    searchInput.addEventListener("input", applyFilters);
    categoryFilter.addEventListener("change", applyFilters);
  </script>
</BaseLayout>
