---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getCategoryLabel, getLevelLabel } from "../../data/navigation";
import defaultBanner from "../../../default-banner.png";

const articleImages = import.meta.glob<{ default: ImageMetadata }>(
  "../../content/knowledge/**/*.{avif,gif,jpeg,jpg,png,webp}",
  { eager: true }
);

const docs = (await getCollection("knowledge"))
  .filter((item) => item.data.status === "ready" && item.data.published !== false)
  .sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    const dateA = a.data.date ? Date.parse(a.data.date) : 0;
    const dateB = b.data.date ? Date.parse(b.data.date) : 0;
    if (dateA !== dateB) return dateB - dateA;
    return a.data.title.localeCompare(b.data.title, "zh-Hans-CN");
  });

const categories = [...new Set(docs.map((doc) => doc.data.category))]
  .sort((a, b) => getCategoryLabel(a).localeCompare(getCategoryLabel(b), "zh-Hans-CN"));

function getBannerSrc(doc: (typeof docs)[number]) {
  if (!doc.data.photos) return defaultBanner.src;
  const bannerPath = `../../content/knowledge/${doc.slug}/${doc.data.photos}`;
  return articleImages[bannerPath]?.default.src ?? defaultBanner.src;
}
---

<BaseLayout title="知识库" description="DaydreamerH 的游戏开发知识库。">
  <section class="toolbar" aria-label="知识库筛选">
    <label class="search-field">
      <span>搜索</span>
      <input id="knowledge-search" type="search" placeholder="输入 C++、UObject、Gameplay..." />
    </label>
    <label class="select-field">
      <span>分类</span>
      <select id="category-filter">
        <option value="all">全部分类</option>
        {categories.map((category) => (
          <option value={category}>{getCategoryLabel(category)}</option>
        ))}
      </select>
    </label>
  </section>

  <section class="knowledge-grid" id="knowledge-grid">
    {docs.map((doc, index) => (
      <article
        class="knowledge-card"
        style={`--card-banner: url("${getBannerSrc(doc)}")`}
        data-title={doc.data.title.toLowerCase()}
        data-tags={doc.data.tags.join(" ").toLowerCase()}
        data-category={doc.data.category}
        data-index={index}
      >
        <div class="card-meta">
          <span class="pill">{getCategoryLabel(doc.data.category)}</span>
          <span>{getLevelLabel(doc.data.level)} · {doc.data.minutes} min</span>
        </div>
        <h2><a href={`/knowledge/${doc.slug}/`}>{doc.data.title}</a></h2>
        <p>{doc.data.description}</p>
        <div class="tag-row">
          {doc.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </article>
    ))}
  </section>

  <p class="empty-state" id="empty-state" hidden>没有匹配的知识点。</p>

  <nav class="pagination" id="knowledge-pagination" aria-label="知识库分页">
    <button type="button" data-page-prev>上一页</button>
    <span data-page-summary></span>
    <button type="button" data-page-next>下一页</button>
  </nav>

  <script>
    const pageSize = 12;
    const searchInput = document.querySelector("#knowledge-search");
    const categoryFilter = document.querySelector("#category-filter");
    const cards = Array.from(document.querySelectorAll(".knowledge-card"));
    const emptyState = document.querySelector("#empty-state");
    const grid = document.querySelector("#knowledge-grid");
    const pagination = document.querySelector("#knowledge-pagination");
    const pagePrev = document.querySelector("[data-page-prev]");
    const pageNext = document.querySelector("[data-page-next]");
    const pageSummary = document.querySelector("[data-page-summary]");
    let currentPage = 1;
    let filteredCards = cards;

    function applyFilters() {
      const query = searchInput.value.trim().toLowerCase();
      const category = categoryFilter.value;

      filteredCards = cards.filter((card) => {
        const text = `${card.dataset.title} ${card.dataset.tags}`;
        const matchesQuery = !query || text.includes(query);
        const matchesCategory = category === "all" || card.dataset.category === category;
        return matchesQuery && matchesCategory;
      });

      currentPage = 1;
      renderPage(false);
    }

    function renderPage(shouldScroll = true) {
      const total = filteredCards.length;
      const pageCount = Math.max(1, Math.ceil(total / pageSize));
      currentPage = Math.min(currentPage, pageCount);
      const start = (currentPage - 1) * pageSize;
      const visibleCards = new Set(filteredCards.slice(start, start + pageSize));

      for (const card of cards) {
        card.hidden = !visibleCards.has(card);
      }

      emptyState.hidden = total !== 0;
      pagination.hidden = total <= pageSize;
      pagePrev.disabled = currentPage <= 1;
      pageNext.disabled = currentPage >= pageCount;
      pageSummary.textContent = total
        ? `第 ${currentPage} / ${pageCount} 页 · ${total} 篇`
        : "0 篇";

      if (shouldScroll && total) {
        grid.scrollIntoView({ block: "start", behavior: "smooth" });
      }
    }

    searchInput.addEventListener("input", applyFilters);
    categoryFilter.addEventListener("change", applyFilters);
    pagePrev.addEventListener("click", () => {
      if (currentPage > 1) {
        currentPage -= 1;
        renderPage();
      }
    });
    pageNext.addEventListener("click", () => {
      const pageCount = Math.max(1, Math.ceil(filteredCards.length / pageSize));
      if (currentPage < pageCount) {
        currentPage += 1;
        renderPage();
      }
    });

    function bindCardTilt(card) {
      card.addEventListener("pointermove", (event) => {
        const rect = card.getBoundingClientRect();
        const x = (event.clientX - rect.left) / rect.width;
        const y = (event.clientY - rect.top) / rect.height;
        const rotateX = (0.5 - y) * 4;
        const rotateY = (x - 0.5) * 4;
        card.style.setProperty("--tilt-x", `${rotateX.toFixed(2)}deg`);
        card.style.setProperty("--tilt-y", `${rotateY.toFixed(2)}deg`);
        card.style.setProperty("--card-tilt-x", `${(rotateX * 0.75).toFixed(2)}deg`);
        card.style.setProperty("--card-tilt-y", `${(rotateY * 0.75).toFixed(2)}deg`);
        card.style.setProperty("--glow-x", `${(x * 100).toFixed(1)}%`);
        card.style.setProperty("--glow-y", `${(y * 100).toFixed(1)}%`);
        card.style.setProperty("--press-shadow-x", `${((0.5 - x) * 10).toFixed(1)}px`);
        card.style.setProperty("--press-shadow-y", `${((0.5 - y) * 12).toFixed(1)}px`);
      });

      card.addEventListener("pointerleave", () => {
        card.style.setProperty("--tilt-x", "0deg");
        card.style.setProperty("--tilt-y", "0deg");
        card.style.setProperty("--card-tilt-x", "0deg");
        card.style.setProperty("--card-tilt-y", "0deg");
        card.style.setProperty("--glow-x", "16%");
        card.style.setProperty("--glow-y", "12%");
        card.style.setProperty("--press-shadow-x", "0px");
        card.style.setProperty("--press-shadow-y", "0px");
      });
    }

    cards.forEach(bindCardTilt);
    applyFilters();
  </script>
</BaseLayout>
