---
import BaseLayout from "../layouts/BaseLayout.astro";
import { graphicsLessonSummaries } from "../data/graphicsLessons";
import defaultBanner from "../../default-banner.png";

const categories = [...new Set(graphicsLessonSummaries.map((lesson) => lesson.category))].sort((a, b) =>
  a.localeCompare(b, "zh-Hans-CN")
);
---

<BaseLayout title="WebGL 实验" description="图形学实验课程列表。">
  <section class="toolbar" aria-label="WebGL 实验筛选">
    <label class="search-field">
      <span>搜索</span>
      <input id="lesson-search" type="search" placeholder="输入 shader、triangle、插值..." />
    </label>
    <label class="select-field">
      <span>分类</span>
      <select id="lesson-category-filter">
        <option value="all">全部分类</option>
        {categories.map((category) => (
          <option value={category}>{category}</option>
        ))}
      </select>
    </label>
  </section>

  <section class="lesson-grid" id="lesson-grid" aria-label="WebGL 实验课程">
    {graphicsLessonSummaries.map((lesson, index) => (
      <article
        class="lesson-library-card"
        style={`--card-banner: url("${defaultBanner.src}")`}
        data-title={`${lesson.title} ${lesson.description}`.toLowerCase()}
        data-category={lesson.category}
        data-index={index}
      >
        <div class="card-meta">
          <span class="pill">{lesson.category}</span>
          <span>{lesson.createdAt}</span>
        </div>
        <h2><a href={`/webgl/${lesson.id}/`}>{lesson.title}</a></h2>
        <p>{lesson.description}</p>
        <div class="tag-row">
          <span>{lesson.level}</span>
          <span>{lesson.checkpointCount} checkpoints</span>
        </div>
      </article>
    ))}
  </section>

  <nav class="pagination" id="lesson-pagination" aria-label="实验课程分页">
    <button type="button" data-lesson-page-prev>上一页</button>
    <span data-lesson-page-summary></span>
    <button type="button" data-lesson-page-next>下一页</button>
  </nav>

  <p class="empty-state" id="lesson-empty-state" hidden>没有匹配的实验课程。</p>

  <script>
    const pageSize = 9;
    const searchInput = document.querySelector("#lesson-search");
    const categoryFilter = document.querySelector("#lesson-category-filter");
    const cards = Array.from(document.querySelectorAll(".lesson-library-card"));
    const emptyState = document.querySelector("#lesson-empty-state");
    const pagination = document.querySelector("#lesson-pagination");
    const pagePrev = document.querySelector("[data-lesson-page-prev]");
    const pageNext = document.querySelector("[data-lesson-page-next]");
    const pageSummary = document.querySelector("[data-lesson-page-summary]");

    let currentPage = 1;
    let filteredCards = cards;

    function applyFilters() {
      const query = searchInput.value.trim().toLowerCase();
      const category = categoryFilter.value;
      filteredCards = cards.filter((card) => {
        const matchesQuery = !query || card.dataset.title.includes(query);
        const matchesCategory = category === "all" || card.dataset.category === category;
        return matchesQuery && matchesCategory;
      });
      currentPage = 1;
      renderPage();
    }

    function renderPage() {
      const total = filteredCards.length;
      const pageCount = Math.max(1, Math.ceil(total / pageSize));
      currentPage = Math.min(currentPage, pageCount);
      const start = (currentPage - 1) * pageSize;
      const visibleCards = new Set(filteredCards.slice(start, start + pageSize));

      for (const card of cards) {
        card.hidden = !visibleCards.has(card);
      }

      emptyState.hidden = total !== 0;
      pagination.hidden = total <= pageSize;
      pagePrev.disabled = currentPage <= 1;
      pageNext.disabled = currentPage >= pageCount;
      pageSummary.textContent = total
        ? `第 ${currentPage} / ${pageCount} 页 · ${total} 个实验`
        : "没有实验";
    }

    searchInput.addEventListener("input", applyFilters);
    categoryFilter.addEventListener("change", applyFilters);
    pagePrev.addEventListener("click", () => {
      if (currentPage > 1) {
        currentPage -= 1;
        renderPage();
      }
    });
    pageNext.addEventListener("click", () => {
      const pageCount = Math.max(1, Math.ceil(filteredCards.length / pageSize));
      if (currentPage < pageCount) {
        currentPage += 1;
        renderPage();
      }
    });

    function bindCardTilt(card) {
      card.addEventListener("pointermove", (event) => {
        const rect = card.getBoundingClientRect();
        const x = (event.clientX - rect.left) / rect.width;
        const y = (event.clientY - rect.top) / rect.height;
        const rotateX = (0.5 - y) * 4;
        const rotateY = (x - 0.5) * 4;
        card.style.setProperty("--tilt-x", `${rotateX.toFixed(2)}deg`);
        card.style.setProperty("--tilt-y", `${rotateY.toFixed(2)}deg`);
        card.style.setProperty("--card-tilt-x", `${(rotateX * 0.75).toFixed(2)}deg`);
        card.style.setProperty("--card-tilt-y", `${(rotateY * 0.75).toFixed(2)}deg`);
        card.style.setProperty("--glow-x", `${(x * 100).toFixed(1)}%`);
        card.style.setProperty("--glow-y", `${(y * 100).toFixed(1)}%`);
        card.style.setProperty("--press-shadow-x", `${((0.5 - x) * 10).toFixed(1)}px`);
        card.style.setProperty("--press-shadow-y", `${((0.5 - y) * 12).toFixed(1)}px`);
      });

      card.addEventListener("pointerleave", () => {
        card.style.setProperty("--tilt-x", "0deg");
        card.style.setProperty("--tilt-y", "0deg");
        card.style.setProperty("--card-tilt-x", "0deg");
        card.style.setProperty("--card-tilt-y", "0deg");
        card.style.setProperty("--glow-x", "16%");
        card.style.setProperty("--glow-y", "12%");
        card.style.setProperty("--press-shadow-x", "0px");
        card.style.setProperty("--press-shadow-y", "0px");
      });
    }

    cards.forEach(bindCardTilt);
    applyFilters();
  </script>
</BaseLayout>
