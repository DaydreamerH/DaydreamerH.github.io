  "checkpoints": [
    {
      "id": "six-directions",
      "title": "六个方向的纹理",
      "concept": "Cubemap 用方向向量而不是二维 UV 来选择六张图中的采样位置。",
      "question": "为什么 cubemap 采样使用的是三维方向向量，而不是普通 2D 纹理的 UV 坐标？",
      "expectedKeywords": [
        "方向",
        "六面",
        "三维",
        "UV",
        "采样"
      ],
      "hint": "环境贴图表示从一点向任意方向看过去的颜色。",
      "files": [
        "main.js",
        "scene.json",
        "skybox.fragment.glsl"
      ],
      "flow": "question_only"
    },
    {
      "id": "show-skybox",
      "title": "显示天空盒",
      "concept": "天空盒是一个围绕相机的巨大立方体，只表达远处环境方向，不参与普通物体位置变化。",
      "question": "观察天空盒后，为什么 skybox 的 view 矩阵应该去掉平移，只保留相机旋转？",
      "expectedKeywords": [
        "平移",
        "旋转",
        "相机",
        "远处环境",
        "方向"
      ],
      "hint": "你移动相机不应该真的靠近天空；转动相机才应该改变看到的方向。",
      "patchId": "01-show-skybox",
      "expectedObservation": "场景出现由六张图片组成的天空盒，拖动相机时它表现为远处环境。",
      "changes": [
        {
          "file": "scene.json",
          "operation": "replace",
          "target": "\"showSkybox\": false,",
          "content": "\"showSkybox\": true,"
        }
      ],
      "files": [
        "scene.json",
        "main.js",
        "skybox.vertex.glsl",
        "skybox.fragment.glsl"
      ],
      "flow": "observe_then_question"
    },
    {
      "id": "xyww-depth",
      "title": "天空盒深度",
      "concept": "pos.xyww 让天空盒经过透视除法后 z 接近 1，使其处于远平面附近。",
      "question": "从 gl_Position = pos.xyww 出发，为什么天空盒会被放在深度范围的远端？",
      "expectedKeywords": [
        "xyww",
        "透视除法",
        "z",
        "w",
        "远平面"
      ],
      "hint": "透视除法后 z_ndc = w / w = 1。",
      "files": [
        "skybox.vertex.glsl",
        "main.js"
      ],
      "flow": "question_only"
    },
    {
      "id": "reflection-vector",
      "title": "反射向量采样",
      "concept": "反射材质用视线方向和表面法线计算反射方向，再从 cubemap 中取环境颜色。",
      "question": "为什么 cube.fs 里要先计算 I = Position - cameraPos，再用 reflect(I, Normal) 得到采样方向？",
      "expectedKeywords": [
        "观察向量",
        "法线",
        "reflect",
        "方向",
        "环境"
      ],
      "hint": "镜面反射方向由入射视线和表面法线共同决定。",
      "patchId": "02-reflect-cubemap",
      "expectedObservation": "立方体表面开始反射天空盒颜色，转动视角时反射区域随观察方向变化。",
      "changes": [
        {
          "file": "scene.json",
          "operation": "replace",
          "target": "\"reflectAmount\": 0.0",
          "content": "\"reflectAmount\": 0.85"
        }
      ],
      "files": [
        "scene.json",
        "geometry.json",
        "cube-reflect.vertex.glsl",
        "cube-reflect.fragment.glsl"
      ],
      "flow": "observe_then_question"
    },
    {
      "id": "normal-space",
      "title": "法线空间一致性",
      "concept": "反射计算要求 Position、cameraPos 和 Normal 在同一个空间中。",
      "question": "为什么反射 shader 要输出世界坐标和世界法线，而不能把模型空间 normal 直接拿来和 world cameraPos 计算？",
      "expectedKeywords": [
        "同一空间",
        "世界坐标",
        "法线",
        "cameraPos",
        "反射"
      ],
      "hint": "向量运算必须在同一个坐标空间中才有几何意义。",
      "files": [
        "cube-reflect.vertex.glsl",
        "cube-reflect.fragment.glsl"
      ],
      "flow": "question_only"
    }
  ]
