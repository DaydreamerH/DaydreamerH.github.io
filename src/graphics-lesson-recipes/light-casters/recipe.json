  "checkpoints": [
    {
      "id": "shared-lighting-inputs",
      "title": "共享的片元输入",
      "concept": "三种光源模型都需要片元世界坐标、法线、UV 和观察位置，只是光线方向与权重来源不同。",
      "question": "为什么 Light Casters 课程必须在 cube.vertex.glsl 中输出世界坐标 vWorldPosition，而不能只把裁剪空间 gl_Position 交给片元 shader？",
      "expectedKeywords": [
        "世界坐标",
        "光源位置",
        "距离",
        "方向",
        "片元"
      ],
      "hint": "点光源和聚光灯需要在每个片元中计算 light.position - FragPos，FragPos 必须在同一个空间中。",
      "files": [
        "cube.vertex.glsl",
        "directional.fragment.glsl",
        "point.fragment.glsl",
        "spot.fragment.glsl"
      ],
      "flow": "question_only"
    },
    {
      "id": "directional-vector",
      "title": "方向光的方向向量",
      "concept": "方向光近似无限远光源，每个片元看到的入射方向相同，因此 shader 使用 -light.direction。",
      "question": "从 directional.fragment.glsl 的 lightDir = normalize(-uLightDirection) 出发，为什么方向光不需要计算 light.position - vWorldPosition？",
      "expectedKeywords": [
        "无限远",
        "平行光",
        "方向相同",
        "位置无关",
        "normalize"
      ],
      "hint": "方向光描述的是一束平行光，所有片元共享入射方向，片元位置不会改变光线方向。",
      "files": [
        "directional.fragment.glsl",
        "scene.json"
      ],
      "flow": "question_only"
    },
    {
      "id": "directional-no-attenuation",
      "title": "方向光没有距离衰减",
      "concept": "方向光只改变角度项，不因片元离某个位置更远而变暗。",
      "question": "观察多个箱体后，为什么方向光模型中远处箱体不会因为距离光源更远而额外变暗？",
      "expectedKeywords": [
        "没有位置",
        "没有距离",
        "attenuation",
        "平行光",
        "光强"
      ],
      "hint": "directional shader 里没有 distance，也没有 1/(constant + linear*d + quadratic*d²) 这样的项。",
      "files": [
        "directional.fragment.glsl",
        "geometry.json"
      ],
      "flow": "question_only"
    },
    {
      "id": "point-light-switch",
      "title": "切换到点光源",
      "concept": "点光源用光源位置减去片元位置得到每个片元自己的入射方向，同时显示光源标记。",
      "question": "切换到点光源后，为什么不同箱体表面的亮面方向不再只由一个全局平行方向决定？",
      "expectedKeywords": [
        "light.position",
        "FragPos",
        "每个片元",
        "方向变化",
        "局部"
      ],
      "hint": "点光源的 lightDir 来自 uLightPos - vWorldPosition，片元位置变了，方向也会变。",
      "patchId": "01-point-light",
      "expectedObservation": "画面出现光源标记，靠近光源的箱体更亮，不同箱体的受光方向随空间位置变化。",
      "changes": [
        {
          "file": "scene.json",
          "operation": "replace_all",
          "content": "{\n  \"shape\": \"multi-cube\",\n  \"mode\": \"point\",\n  \"camera\": {\n    \"type\": \"perspective\",\n    \"fov\": 45,\n    \"position\": [\n      3.4,\n      2.2,\n      5.2\n    ],\n    \"lookAt\": [\n      0,\n      0.2,\n      -2\n    ]\n  },\n  \"material\": {\n    \"vertexShader\": \"cube.vertex.glsl\",\n    \"fragmentShader\": \"point.fragment.glsl\"\n  },\n  \"textures\": {\n    \"diffuse\": \"diffuse-map.txt\",\n    \"specular\": \"specular-map.txt\"\n  },\n  \"lightMarker\": {\n    \"enabled\": true,\n    \"vertexShader\": \"light.vertex.glsl\",\n    \"fragmentShader\": \"light.fragment.glsl\",\n    \"radius\": 0.09\n  },\n  \"uniforms\": {\n    \"uLightColor\": [\n      1,\n      1,\n      1\n    ],\n    \"uLightDirection\": [\n      -0.2,\n      -1,\n      -0.3\n    ],\n    \"uLightPos\": [\n      1.2,\n      1,\n      2\n    ],\n    \"uSpotDirection\": [\n      -0.45,\n      -0.2,\n      -1\n    ],\n    \"uAmbient\": [\n      0.2,\n      0.2,\n      0.2\n    ],\n    \"uDiffuse\": [\n      0.5,\n      0.5,\n      0.5\n    ],\n    \"uSpecular\": [\n      1,\n      1,\n      1\n    ],\n    \"uConstant\": 1,\n    \"uLinear\": 0.09,\n    \"uQuadratic\": 0.032,\n    \"uCutOff\": 0.976296,\n    \"uOuterCutOff\": 0.953717,\n    \"uShininess\": 32\n  },\n  \"mesh\": {\n    \"scale\": 1\n  },\n  \"animated\": false\n}"
        }
      ],
      "files": [
        "scene.json",
        "point.fragment.glsl",
        "geometry.json"
      ],
      "flow": "observe_then_question"
    },
    {
      "id": "attenuation-formula",
      "title": "距离衰减公式",
      "concept": "点光源用 constant、linear、quadratic 组成经验衰减曲线，quadratic 项让远距离光强下降更明显。",
      "question": "从 attenuation = 1 / (constant + linear * d + quadratic * d * d) 出发，为什么 quadratic 项会让远处物体比近处物体更快变暗？",
      "expectedKeywords": [
        "d²",
        "平方",
        "分母",
        "距离",
        "衰减"
      ],
      "hint": "当 d 变大时，d² 的增长速度快于 d，会更快抬高分母，从而压低 attenuation。",
      "files": [
        "point.fragment.glsl",
        "scene.json"
      ],
      "flow": "question_only"
    },
    {
      "id": "attenuation-scope",
      "title": "衰减影响全部光照分量",
      "concept": "在点光源模型中，ambient、diffuse、specular 最终一起乘以 attenuation，表示光源能量随距离减弱。",
      "question": "为什么 point.fragment.glsl 把 ambient + diffuse + specular 的结果整体乘以 attenuation，而不是只衰减 diffuse？",
      "expectedKeywords": [
        "能量",
        "距离",
        "ambient",
        "specular",
        "统一"
      ],
      "hint": "这里的 attenuation 表示来自点光源的整体贡献随距离变弱，不只是 Lambert 项变弱。",
      "files": [
        "point.fragment.glsl"
      ],
      "flow": "question_only"
    },
    {
      "id": "spot-light-switch",
      "title": "切换到聚光灯",
      "concept": "聚光灯在点光源基础上增加方向和角度阈值，只让光锥内的片元获得强光。",
      "question": "切换到聚光灯后，为什么有些离光源不远的箱体仍然会明显变暗？",
      "expectedKeywords": [
        "光锥",
        "方向",
        "theta",
        "cutOff",
        "角度"
      ],
      "hint": "聚光灯不仅看距离，还看片元方向是否落在光源朝向的锥体内。",
      "patchId": "02-spot-light",
      "expectedObservation": "画面变成手电筒式照明，只有光锥方向附近的箱体获得主要 diffuse/specular。",
      "changes": [
        {
          "file": "scene.json",
          "operation": "replace_all",
          "content": "{\n  \"shape\": \"multi-cube\",\n  \"mode\": \"spot\",\n  \"camera\": {\n    \"type\": \"perspective\",\n    \"fov\": 45,\n    \"position\": [\n      3.4,\n      2.2,\n      5.2\n    ],\n    \"lookAt\": [\n      0,\n      0.2,\n      -2\n    ]\n  },\n  \"material\": {\n    \"vertexShader\": \"cube.vertex.glsl\",\n    \"fragmentShader\": \"spot.fragment.glsl\"\n  },\n  \"textures\": {\n    \"diffuse\": \"diffuse-map.txt\",\n    \"specular\": \"specular-map.txt\"\n  },\n  \"lightMarker\": {\n    \"enabled\": true,\n    \"vertexShader\": \"light.vertex.glsl\",\n    \"fragmentShader\": \"light.fragment.glsl\",\n    \"radius\": 0.09\n  },\n  \"uniforms\": {\n    \"uLightColor\": [\n      1,\n      1,\n      1\n    ],\n    \"uLightDirection\": [\n      -0.2,\n      -1,\n      -0.3\n    ],\n    \"uLightPos\": [\n      1.2,\n      1,\n      2\n    ],\n    \"uSpotDirection\": [\n      -0.45,\n      -0.2,\n      -1\n    ],\n    \"uAmbient\": [\n      0.1,\n      0.1,\n      0.1\n    ],\n    \"uDiffuse\": [\n      0.8,\n      0.8,\n      0.8\n    ],\n    \"uSpecular\": [\n      1,\n      1,\n      1\n    ],\n    \"uConstant\": 1,\n    \"uLinear\": 0.09,\n    \"uQuadratic\": 0.032,\n    \"uCutOff\": 0.976296,\n    \"uOuterCutOff\": 0.953717,\n    \"uShininess\": 32\n  },\n  \"mesh\": {\n    \"scale\": 1\n  },\n  \"animated\": false\n}"
        }
      ],
      "files": [
        "scene.json",
        "spot.fragment.glsl",
        "geometry.json"
      ],
      "flow": "observe_then_question"
    },
    {
      "id": "spot-soft-edge",
      "title": "聚光灯软边缘",
      "concept": "cutOff 与 outerCutOff 之间用线性归一化得到 intensity，避免光锥边缘硬切。",
      "question": "为什么 intensity = clamp((theta - outerCutOff) / (cutOff - outerCutOff), 0, 1) 能形成聚光灯软边缘，而不是突然从亮变黑？",
      "expectedKeywords": [
        "theta",
        "outerCutOff",
        "cutOff",
        "插值",
        "clamp"
      ],
      "hint": "当 theta 落在内外角之间时，分式会产生 0 到 1 之间的连续权重。",
      "files": [
        "spot.fragment.glsl",
        "scene.json"
      ],
      "flow": "question_only"
    },
    {
      "id": "animated-spot-comparison",
      "title": "动态比较光锥",
      "concept": "缓慢摆动聚光灯方向，让用户观察 spot direction 改变时，受光区域如何随角度项移动。",
      "question": "当聚光方向缓慢摆动时，哪些变化来自点光源的距离衰减，哪些变化来自聚光灯的角度 intensity？",
      "expectedKeywords": [
        "距离衰减",
        "角度",
        "intensity",
        "光锥",
        "分离"
      ],
      "hint": "距离衰减主要跟光源位置到片元的距离有关；光锥变化主要跟 theta 和 cutOff 的关系有关。",
      "patchId": "03-animated-spot",
      "expectedObservation": "聚光灯方向缓慢摆动，受光区域随光锥移动，但距离较远处仍保持较弱。",
      "changes": [
        {
          "file": "scene.json",
          "operation": "replace_all",
          "content": "{\n  \"shape\": \"multi-cube\",\n  \"mode\": \"spot\",\n  \"camera\": {\n    \"type\": \"perspective\",\n    \"fov\": 45,\n    \"position\": [\n      3.4,\n      2.2,\n      5.2\n    ],\n    \"lookAt\": [\n      0,\n      0.2,\n      -2\n    ]\n  },\n  \"material\": {\n    \"vertexShader\": \"cube.vertex.glsl\",\n    \"fragmentShader\": \"spot.fragment.glsl\"\n  },\n  \"textures\": {\n    \"diffuse\": \"diffuse-map.txt\",\n    \"specular\": \"specular-map.txt\"\n  },\n  \"lightMarker\": {\n    \"enabled\": true,\n    \"vertexShader\": \"light.vertex.glsl\",\n    \"fragmentShader\": \"light.fragment.glsl\",\n    \"radius\": 0.09\n  },\n  \"uniforms\": {\n    \"uLightColor\": [\n      1,\n      1,\n      1\n    ],\n    \"uLightDirection\": [\n      -0.2,\n      -1,\n      -0.3\n    ],\n    \"uLightPos\": [\n      1.2,\n      1,\n      2\n    ],\n    \"uSpotDirection\": [\n      -0.45,\n      -0.2,\n      -1\n    ],\n    \"uAmbient\": [\n      0.1,\n      0.1,\n      0.1\n    ],\n    \"uDiffuse\": [\n      0.8,\n      0.8,\n      0.8\n    ],\n    \"uSpecular\": [\n      1,\n      1,\n      1\n    ],\n    \"uConstant\": 1,\n    \"uLinear\": 0.09,\n    \"uQuadratic\": 0.032,\n    \"uCutOff\": 0.976296,\n    \"uOuterCutOff\": 0.953717,\n    \"uShininess\": 32\n  },\n  \"mesh\": {\n    \"scale\": 1\n  },\n  \"animated\": true\n}"
        }
      ],
      "files": [
        "scene.json",
        "spot.fragment.glsl",
        "main.js"
      ],
      "flow": "observe_then_question"
    },
    {
      "id": "model-comparison",
      "title": "三种 Light Caster 的模型边界",
      "concept": "方向光、点光源、聚光灯分别增加位置和角度约束，表达不同物理近似与控制需求。",
      "question": "如果按输入变量和公式复杂度比较，directional、point、spot 三种 light caster 分别多引入了哪些约束？为什么这会改变画面中的空间分布？",
      "expectedKeywords": [
        "direction",
        "position",
        "attenuation",
        "cutOff",
        "空间分布"
      ],
      "hint": "方向光只有方向；点光源增加位置和距离；聚光灯再增加朝向和角度阈值。",
      "files": [
        "directional.fragment.glsl",
