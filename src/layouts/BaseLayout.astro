---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "DaydreamerH 的 UE5 游戏开发训练工作台。" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | DaydreamerH</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark">DH</span>
          <span>
            <strong>DaydreamerH</strong>
            <small>UE5 Training Desk</small>
          </span>
        </a>
        <nav class="main-nav" aria-label="主导航">
          <a href="/">工作台</a>
          <a href="/knowledge/">知识库</a>
          <a href="/coach/">AI Coach</a>
          <a href="/#modules">模块</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
