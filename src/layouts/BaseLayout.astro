---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "DaydreamerH 的游戏开发训练工作台。" } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "工作台", active: currentPath === "/" },
  { href: "/knowledge/", label: "知识库", active: currentPath.startsWith("/knowledge") },
  { href: "/coach/", label: "AI Coach", active: currentPath.startsWith("/coach") },
  { href: "/webgl/", label: "WebGL 实验", active: currentPath.startsWith("/webgl") }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | DaydreamerH</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark">DH</span>
          <span>
            <strong>DaydreamerH</strong>
            <small>Game Dev Training Desk</small>
          </span>
        </a>
        <nav class="main-nav" aria-label="主导航">
          {navItems.map((item) => (
            <a href={item.href} class={item.active ? "is-active" : ""} aria-current={item.active ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
