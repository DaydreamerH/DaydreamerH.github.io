---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  coachHref?: string;
}

const {
  title,
  description = "DaydreamerH 的游戏开发学习记录与测试页面。",
  coachHref = "/coach/"
} = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "工作台", active: currentPath === "/" },
  { href: "/knowledge/", label: "知识库", active: currentPath.startsWith("/knowledge") },
  { href: coachHref, label: "AI Coach", active: currentPath.startsWith("/coach") },
  { href: "/webgl/", label: "WebGL 实验", active: currentPath.startsWith("/webgl") }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | DaydreamerH</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar" data-topbar>
        <a class="brand" href="/">
          <span class="brand-mark">DH</span>
          <span>
            <strong>DaydreamerH</strong>
            <small>Game Dev Training Desk</small>
          </span>
        </a>
        <nav class="main-nav" aria-label="主导航">
          {navItems.map((item) => (
            <a href={item.href} class={item.active ? "is-active" : ""} aria-current={item.active ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
    <script>
      const topbar = document.querySelector("[data-topbar]");
      const topRestoreThreshold = 72;
      const hideThreshold = 144;
      const scrollDeltaThreshold = 6;
      let lastScrollY = window.scrollY;
      let ticking = false;

      function syncTopbar() {
        if (!topbar) return;

        const currentScrollY = Math.max(window.scrollY, 0);
        const scrollDelta = currentScrollY - lastScrollY;
        const isAtTop = currentScrollY <= topRestoreThreshold;

        topbar.classList.toggle("is-detached", !isAtTop);

        if (isAtTop) {
          topbar.classList.remove("is-hidden");
        } else if (scrollDelta > scrollDeltaThreshold && currentScrollY > hideThreshold) {
          topbar.classList.add("is-hidden");
        } else if (scrollDelta < -scrollDeltaThreshold) {
          topbar.classList.remove("is-hidden");
        }

        lastScrollY = currentScrollY;
        ticking = false;
      }

      window.addEventListener(
        "scroll",
        () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(syncTopbar);
        },
        { passive: true }
      );

      syncTopbar();
    </script>
  </body>
</html>
